<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_g2p_kebele_tree" model="ir.ui.view">
        <field name="name">view_g2p_kebele_tree</field>
        <field name="model">g2p.kebele</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
         <tree create="true" delete="true" edit="true" editable="bottom">
                <field name="woreda" required="1" />
                <field name="code" required="1" />
                <field name="name" required="1" />
            </tree>
        </field>
    </record>

    <record id="g2p_kebele_view_tree_action" model="ir.actions.act_window">
        <field name="name">kebeles</field>
        <field name="res_model">g2p.kebele</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Add an Farming Type!
                </p><p>
                    Click the create button to enter a new Farm type.
                </p>
            </field>
    </record>

    <menuitem
        id="g2p_kebele_menu"
        action="g2p_kebele_view_tree_action"
        name="Kebeles"
        sequence="500"
        parent="g2p_registry_base.g2p_configuration_menu_root"
    />
</odoo>
