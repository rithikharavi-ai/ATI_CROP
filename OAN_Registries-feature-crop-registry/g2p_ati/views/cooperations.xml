<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="g2p_primary_cooperative_tree" model="ir.ui.view">
        <field name="name">g2p.primary.cooperative.tree</field>
        <field name="model">g2p.primary.cooperative</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <tree create="true" delete="true" edit="true" editable="bottom">
                <field name="code" required="1" />
                <field name="name" required="1" />
            </tree>
        </field>
    </record>
    <record id="g2p_cooperative_union_tree" model="ir.ui.view">
        <field name="name">g2p.cooperative.union.tree</field>
        <field name="model">g2p.cooperative.union</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <tree create="true" delete="true" edit="true" editable="bottom">
                <field name="code" required="1" />
                <field name="name" required="1" />
            </tree>
        </field>
    </record>

    <record id="g2_primary_cooperative_action" model="ir.actions.act_window">
        <field name="name">Primary Cooperative</field>
        <field name="res_model">g2p.primary.cooperative</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="g2p_cooperative_union_action" model="ir.actions.act_window">
        <field name="name">Cooperative Union</field>
        <field name="res_model">g2p.cooperative.union</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="g2p_primary_cooperative_menu"
        action="g2_primary_cooperative_action"
        name="Primary Cooperations"
        sequence="620"
        parent="g2p_registry_base.g2p_configuration_menu_root"
    />

    <menuitem
        id="g2p_cooperative_union_menu"
        action="g2p_cooperative_union_action"
        name="Cooperative Unions"
        sequence="620"
        parent="g2p_registry_base.g2p_configuration_menu_root"
    />
</odoo>
