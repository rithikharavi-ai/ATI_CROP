<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="g2p_water_source_tree" model="ir.ui.view">
        <field name="name">g2p.water.source.view.form</field>
        <field name="model">g2p.water.source</field>
        <field name="arch" type="xml">
            <tree create="true" delete="true" edit="true" editable="bottom">
                    <field name="name" />
                    <field name="code" />
            </tree>
        </field>
    </record>
    <record id="g2p_water_source_action" model="ir.actions.act_window">
        <field name="name">Water Sources</field>
        <field name="res_model">g2p.water.source</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem
        id="g2p_water_menu"
        action="g2p_water_source_action"
        name="Water Sources"
        sequence="620"
        parent="g2p_registry_base.g2p_configuration_menu_root"
    />
</odoo>
