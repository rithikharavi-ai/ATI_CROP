<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_crop_variety_tree" model="ir.ui.view">
        <field name="name">view_season_tree</field>
        <field name="model">g2p.crop.variety</field>
        <field name="arch" type="xml">
            <tree create="true" delete="true" edit="true" editable="bottom">
                <field name="name"/>
                <field name="code"/>
                <field name="crop_id"/>

            </tree>
        </field>
    </record>
    <record id="g2p_crop_variety_view_tree_action" model="ir.actions.act_window">
        <field name="name">Crop Variety</field>
        <field name="res_model">g2p.crop.variety</field>
        <field name="view_mode">tree</field>
    </record>
    <menuitem
            id="g2p_crop_variety_menu"
            action="g2p_crop_variety_view_tree_action"
            name="Crop Variety"
            sequence="520"
            parent="g2p_registry_base.g2p_configuration_menu_root"
    />
</odoo>
