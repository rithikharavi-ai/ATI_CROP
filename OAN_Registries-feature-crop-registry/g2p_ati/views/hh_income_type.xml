<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="g2p_hh_income_tree" model="ir.ui.view">
        <field name="name">g2p.hh.income.view.form</field>
        <field name="model">g2p.hh.income</field>
        <field name="arch" type="xml">
            <tree create="true" delete="true" edit="true" editable="bottom">
                    <field name="name" />
                    <field name="code" />
            </tree>
        </field>
    </record>

    <record id="g2p_hh_income_action" model="ir.actions.act_window">
        <field name="name">Household Income</field>
        <field name="res_model">g2p.hh.income</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="g2p_hh_invcome_menu"
        action="g2p_hh_income_action"
        name="Household Income"
        sequence="620"
        parent="g2p_registry_base.g2p_configuration_menu_root"
    />
</odoo>
