<?xml version="1.0" encoding="utf-8" ?>
<odoo>

  <record id="g2p_machinery_tree" model="ir.ui.view">
        <field name="name">g2p.machinery.tree</field>
        <field name="model">g2p.machinery</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
         <tree create="true" delete="true" edit="true" editable="bottom">
                <field name="code" required="1" />
                <field name="name" required="1" />
            </tree>
        </field>
    </record>


<record id="g2p_machinery_action" model="ir.actions.act_window">
    <field name="name">Machineries</field>
    <field name="res_model">g2p.machinery</field>
    <field name="view_mode">tree,form</field>
</record>



    <menuitem
        id="g2p_machinery_menu"
        action="g2p_machinery_action"
        name="Machineries"
        sequence="622"
        parent="g2p_registry_base.g2p_configuration_menu_root"
    />
</odoo>
