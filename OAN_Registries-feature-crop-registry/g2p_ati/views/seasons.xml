<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_season_tree" model="ir.ui.view">
        <field name="name">view_season_tree</field>
        <field name="model">g2p.season</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <tree create="true" delete="true" edit="true" editable="bottom">
                <field name="name" />
                <field name="start_gc" />
                <field name="end_gc" />
                <field name="start_month" />
                <field name="start_day" />
                <field name="end_month" />
                <field name="end_day" />

            </tree>
        </field>
    </record>
    <record id="g2p_season_view_tree_action" model="ir.actions.act_window">
        <field name="name">Seasons</field>
        <field name="res_model">g2p.season</field>
        <field name="view_mode">tree,form,graph</field>
    </record>
    <menuitem
        id="g2p_season_menu"
        action="g2p_season_view_tree_action"
        name="Seasons"
        sequence="610"
        parent="g2p_registry_base.g2p_configuration_menu_root"
    />
</odoo>
