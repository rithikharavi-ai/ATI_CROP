    <!-- Farmer -->
    <record id="g2p_registry_farmer_form_view_inherit_no_create" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.no.create</field>
        <field name="model">res.partner</field>
        <field name="mode">primary</field>
        <field name="inherit_id" ref="g2p_ati.g2p_registry_individual_form_view_inherit" />
        <field name="arch" type="xml">
            <xpath expr="//form" position="attributes">
                <attribute name="create">False</attribute>
            </xpath>
        </field>
    </record>
<record id="g2p_registry_farmer_tree_view_inherit_no_create" model="ir.ui.view">
    <field name="name">res.partner.tree.inherit.no.create</field>
    <field name="model">res.partner</field>
    <field name="mode">primary</field>
    <field name="inherit_id" ref="g2p_ati.g2p_registry_individual_tree_view_inherit" />
    <field name="arch" type="xml">
        <xpath expr="//tree" position="attributes">
            <attribute name="create">False</attribute>
        </xpath>

        <xpath expr="//field[@name='name']" position="before">
            <field name="farmer_id" />
        </xpath>

         <xpath expr="//field[@name='is_farmer']" position="attributes">
                <attribute name="column_invisible">1</attribute>

        </xpath>

    </field>
</record>






    <record id="action_farmers_view" model="ir.actions.act_window">
        <field name="name">Farmer</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">tree,form</field>
        <field name="context">
            {'default_is_registrant':True,'default_is_group':False,'default_is_farmer':'yes'}</field>
        <field name="domain">[('is_registrant', '=', True),('is_group','=',False),
            ('is_farmer','=','yes')]</field>
        <field
            name="view_ids"
            eval="[(5, 0, 0),
    (0,0,{'view_mode': 'tree', 'view_id': ref('g2p_registry_farmer_tree_view_inherit_no_create')}),
    (0,0,{'view_mode': 'form', 'view_id': ref('g2p_registry_farmer_form_view_inherit_no_create')})]"
        />
    </record>

    <menuitem
        id="menu_action_farmer"
        name="Farmers"
        action="action_farmers_view"
        web_icon="g2p_ati,static/description/farmer.png"
        sequence="2"
    groups="group_data_enumerator,group_data_admin,group_data_validator,group_system_admin,g2p_registry_base.group_g2p_admin,g2p_registry_base.group_g2p_registrar"

