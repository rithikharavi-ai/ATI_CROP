<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template id="g2p_ati_web_login_layout" inherit_id="web.login_layout" priority="200">
        <xpath expr="//div[hasclass('oe_website_login_container')] | //div[hasclass('container')]" position="replace">
            <link rel="stylesheet" href="/g2p_ati/static/src/css/web_login.css" />
            <div class="ati-web-login-page">
                <div class="ati-web-login-wrapper">
                    <div class="ati-web-login-card">
                        <div class="ati-web-login-logo-box">
                            <img
                                t-attf-src="/web/binary/company_logo{{ '?dbname='+db if db else '' }}"
                                class="ati-web-login-logo"
                                alt="Logo"
                            />
                        </div>
                        <t t-out="0" />
                    </div>
                    <div class="ati-web-login-help">
                        Facing any challenges?
                        <a href="/web/reset_password">Help</a>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <template id="g2p_ati_web_login_form" inherit_id="web.login" priority="200">
        <xpath expr="//form[hasclass('oe_login_form')]" position="replace">
            <form
                class="oe_login_form"
                role="form"
                t-attf-action="/web/login"
                method="post"
                onsubmit="this.action = '/web/login' + location.hash"
            >
                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()" />

                <div class="form-group mb-3 field-db" t-if="databases and len(databases) &gt; 1">
                    <label for="db" class="form-label">Database</label>
                    <div t-attf-class="input-group {{'input-group-sm' if form_small else ''}}">
                        <input
                            type="text"
                            name="db"
                            t-att-value="request.db"
                            id="db"
                            t-attf-class="form-control #{'form-control-sm' if form_small else ''}"
                            required="required"
                            readonly="readonly"
                        />
                        <a role="button" href="/web/database/selector" class="btn btn-secondary">
                            Select
                            <i class="fa fa-database" role="img" aria-label="Database" title="Database" />
                        </a>
                    </div>
                </div>

                <div class="form-group mb-3 field-login">
                    <label for="login" class="form-label">Email</label>
                    <input
                        type="text"
                        placeholder="Enter Email Address"
                        name="login"
                        t-att-value="login"
                        id="login"
                        t-attf-class="form-control #{'form-control-sm' if form_small else ''}"
                        required="required"
                        autocomplete="username"
                        autofocus="autofocus"
                        autocapitalize="off"
                    />
                </div>

                <div class="form-group mb-3 field-password">
                    <div class="d-flex justify-content-between align-items-center">
                        <label for="password" class="form-label mb-0">Password</label>
                        <a class="ati-web-reset-password" href="/web/reset_password">Reset Password</a>
                    </div>
                    <input
                        type="password"
                        placeholder="Enter Password"
                        name="password"
                        id="password"
                        t-attf-class="form-control #{'form-control-sm' if form_small else ''}"
                        required="required"
                        autocomplete="current-password"
                        t-att-autofocus="'autofocus' if login else None"
                        maxlength="4096"
                    />
                </div>

                <p class="alert alert-danger" t-if="error" role="alert">
                    <t t-esc="error" />
                </p>
                <p class="alert alert-success" t-if="message" role="status">
                    <t t-esc="message" />
                </p>

                <div
                    t-attf-class="clearfix oe_login_buttons text-center d-grid mb-1 {{'pt-2' if form_small else 'pt-3'}}"
                >
                    <button type="submit" class="btn btn-primary">Login</button>
                    <t t-if="debug">
                        <button type="submit" name="redirect" value="/web/become" class="btn btn-link btn-sm">
                            Log in as superuser
                        </button>
                    </t>
                    <div class="o_login_auth" />
                </div>

                <input type="hidden" name="redirect" t-att-value="redirect" />
            </form>
        </xpath>
    </template>
</odoo>
