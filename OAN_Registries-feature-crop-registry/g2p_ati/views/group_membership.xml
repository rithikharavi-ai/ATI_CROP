<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="view_groups_form_membership_id_inherit" model="ir.ui.view">
        <field name="name">res.partner.view.form.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="g2p_registry_membership.view_groups_form_membership" />
        <field name="arch" type="xml">

            <xpath expr="//page[@name='members']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>



            <xpath expr="//page[@name='ids']" position="before">
                <page string="Members" name="members">
                    <group col="4" colspan="4">
                        <field name="group_membership_ids" readonly="disabled" nolabel="1" colspan="4">
                            <tree editable="top" default_order='status asc,ended_date asc'>
                                <button
                                    name="open_individual_form"
                                    type="object"
                                    icon="fa-external-link"
                                    class="btn-success"
                                    title="Open Individual Form"
                                />
                                <field
                                    name="individual"
                                    domain="[('is_registrant','=',True),('is_group','=',False)]"
                                    options="{'no_create':True}"
                                    string="Member Name"
                                    context="{'form_view_ref':'g2p_registry_individual.view_individuals_form'}"
                                />
                                <field name="individual_birthdate" string="Date of Birth" />
                                <field name="individual_gender" string="Sex" />
                                <field
                                    name="kind"
                                    string="Relation"
                                    widget="many2many_tags"
                                    options="{'no_open':True, 'no_create_edit':True, 'no_create':True, 'no_quick_create':True}"
                                />

                            </tree>
                        </field>
                    </group>
                </page>
            </xpath>

        </field>
    </record>





    <record id="g2p_registry_membership.view_individuals_form_membership" model="ir.ui.view">

        <field name="arch" type="xml">

            <xpath expr="//page[@name='basic_info']" position="after">
                <page string="Households">
                    <field
                        name="individual_membership_ids"
                        readonly="true"
                        create="false"
                        nolabel="1"
                        colspan="4"
                    >
                        <tree editable="top">
                            <button
                                name="open_group_form"
                                type="object"
                                icon="fa-external-link"
                                class="btn-success"
                                title="Open group form"
                            />
                            <field
                                name="group"
                                domain="[('is_registrant','=',True),('is_group','=',True)]"
                                options="{'no_create':True}"
                                string="Household Name"
                                context="{'form_view_ref':'g2p_registry_group.view_groups_form'}"
                            />
                            <field
                                name="kind"
                                string="Relation"
                                widget="many2many_tags"
                                options="{'no_open':True, 'no_create_edit':True}"
                            />
                        </tree>
                    </field>
                </page>
            </xpath>



        </field>
    </record>

</odoo>
