<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="g2p_import_source_tree_view" model="ir.ui.view">
        <field name="name">g2p.import.source.tree</field>
        <field name="model">g2p.import.source</field>
        <field name="arch" type="xml">
            <tree string="Import Sources" editable="bottom">
                <field name="name" />
                <field name="code" />
            </tree>
        </field>
    </record>

    <record id="g2p_import_source_form_view" model="ir.ui.view">
        <field name="name">g2p.import.source.form</field>
        <field name="model">g2p.import.source</field>
        <field name="arch" type="xml">
            <form string="Import Source">
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="code" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="g2p_import_source_action" model="ir.actions.act_window">
        <field name="name">Import Sources</field>
        <field name="res_model">g2p.import.source</field>
        <field name="view_mode">tree,form</field>
        <field
            name="view_ids"
            eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'tree', 'view_id': ref('g2p_import_source_tree_view')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('g2p_import_source_form_view')})]"
        />
    </record>

    <menuitem
        id="g2p_import_source_menu_main"
        name="Import Sources"
        action="g2p_import_source_action"
        parent="g2p_configuration_menu_root_main"
        sequence="630"
        groups="g2p_registry_base.group_g2p_admin,group_data_validator"
    />
</odoo>
