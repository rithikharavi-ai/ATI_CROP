<odoo>
    <record id="view_wizard_rejection_reason_form" model="ir.ui.view">
        <field name="name">rejection.reason.wizard.form</field>
        <field name="model">g2p.rejection.reason.wizard</field>
        <field name="arch" type="xml">
            <form string="Enter Rejection Reason">
                <group>
                    <field name="reason" />
                </group>
                <footer>
                    <button string="Confirm" class="btn-primary" type="object" name="confirm_rejection" />
                    <button string="Cancel" class="btn-danger" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_wizard_rejection_reason" model="ir.actions.act_window">
        <field name="name">Enter Rejection Reason</field>
        <field name="res_model">g2p.rejection.reason.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
