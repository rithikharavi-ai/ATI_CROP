<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_odk_import_form_webhook_consent" model="ir.ui.view">
        <field name="name">odk.import.form.webhook.consent</field>
        <field name="model">odk.import</field>
        <field name="inherit_id" ref="g2p_odk_importer.view_odk_import_form" />
        <field name="arch" type="xml">
            <xpath expr="//group[.//field[@name='enable_async']]" position="after">
                <group string="Webhook Settings" invisible="not is_consent_import">
                    <field name="is_consent_import" />
                    <field name="enable_webhook_import" />
                    <field name="webhook_url" readonly="1" widget="url" />
                    <field name="webhook_secret" password="True" />
                    <button
                        name="action_regenerate_webhook_secret"
                        type="object"
                        string="Regenerate Secret"
                        class="btn-secondary"
                    />
                </group>
            </xpath>
        </field>
    </record>
</odoo>
