<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <function model="g2p.datashare.config.websub" name="_cleanup_old_consent_data_field_ui" />

    <record id="g2p_registry_datashare_websub.menu_datashare_config_websub" model="ir.ui.menu">
        <field name="name">WebSub</field>
        <field name="action" eval="False" />
    </record>

    <menuitem
        id="menu_datashare_config_websub_configs"
        name="WebSub Datashare Configs"
        parent="g2p_registry_datashare_websub.menu_datashare_config_websub"
        action="g2p_registry_datashare_websub.action_datashare_config_websub"
        sequence="10"
        groups="g2p_registry_base.group_g2p_admin"
    />

    <record id="view_g2p_consent_data_field_tree" model="ir.ui.view">
        <field name="name">g2p.consent.data.field.tree</field>
        <field name="model">g2p.consent.data.field</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="code" />
                <field name="payload_key" />
                <field name="source_path_display" string="Source Path" />
                <field name="active" />
            </tree>
        </field>
    </record>

    <record id="view_g2p_consent_data_field_form" model="ir.ui.view">
        <field name="name">g2p.consent.data.field.form</field>
        <field name="model">g2p.consent.data.field</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="source_path_display" invisible="1" />
                    <group col="2">
                        <group>
                            <field name="name" />
                            <field name="code" />
                        </group>
                        <group>
                            <field name="payload_key" />
                            <field name="active" />
                        </group>
                    </group>
                    <group>
                        <field
                            name="source_path"
                            string="Source Field"
                            widget="g2p_field_path_picker"
                            options="{'purpose': 'source', 'display_field': 'source_path_display'}"
                        />
                    </group>
                    <notebook>
                        <page string="Advanced Mapping">
                            <field name="mapping_line_ids" nolabel="1" colspan="4">
                                <tree editable="bottom">
                                    <field name="payload_key" />
                                    <field name="source_path_display" column_invisible="1" />
                                    <field name="filter_path_display" column_invisible="1" />
                                    <field name="fallback_filter_path_display" column_invisible="1" />
                                    <field
                                        name="source_path"
                                        string="Source Field"
                                        widget="g2p_field_path_picker"
                                        options="{'purpose': 'source', 'display_field': 'source_path_display'}"
                                    />
                                    <field name="filter_model_display" string="Filter Model" readonly="1" />
                                    <field
                                        name="filter_path"
                                        string="Filter Field"
                                        widget="g2p_field_path_picker"
                                        options="{'purpose': 'filter', 'source_field': 'source_path', 'display_field': 'filter_path_display'}"
                                    />
                                    <field name="filter_operator" string="Operator" />
                                    <field name="filter_value" />
                                </tree>
                                <form string="Advanced Mapping Line">
                                    <field name="source_path_display" invisible="1" />
                                    <field name="filter_path_display" invisible="1" />
                                    <field name="fallback_filter_path_display" invisible="1" />
                                    <group col="2">
                                        <group>
                                            <field name="payload_key" />
                                            <field
                                                name="source_path"
                                                string="Source Field"
                                                widget="g2p_field_path_picker"
                                                options="{'purpose': 'source', 'display_field': 'source_path_display'}"
                                            />
                                        </group>
                                        <group>
                                            <field name="filter_model_display" readonly="1" />
                                            <field
                                                name="filter_path"
                                                string="Filter Field"
                                                widget="g2p_field_path_picker"
                                                options="{'purpose': 'filter', 'source_field': 'source_path', 'display_field': 'filter_path_display'}"
                                            />
                                            <field name="filter_operator" />
                                            <field name="filter_value" />
                                        </group>
                                    </group>
                                    <group col="2" string="Fallback Filter">
                                        <group>
                                            <field name="fallback_filter_model_display" readonly="1" />
                                            <field
                                                name="fallback_filter_path"
                                                string="Fallback Field"
                                                widget="g2p_field_path_picker"
                                                options="{'purpose': 'filter', 'source_field': 'source_path', 'display_field': 'fallback_filter_path_display'}"
                                            />
                                            <field name="fallback_filter_operator" />
                                            <field name="fallback_filter_value" />
                                        </group>
                                    </group>
                                </form>
                            </field>
                        </page>

                        <!-- <page string="Preview">
                            <group col="2">
                                <group>
                                    <field name="preview_partner_id" />
                                </group>
                            </group>
                            <group>
                                <field name="preview_payload" widget="g2p_data_field_preview" nolabel="1" />
                            </group>
                        </page> -->


                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_g2p_consent_data_field" model="ir.actions.act_window">
        <field name="name">Data Fields</field>
        <field name="res_model">g2p.consent.data.field</field>
        <field name="view_mode">tree,form</field>
    </record>

  
    <menuitem
        id="menu_g2p_consent_data_fields"
        name="Data Fields"
        parent="g2p_registry_datashare_websub.menu_datashare_config_websub"
        action="action_g2p_consent_data_field"
        sequence="20"
        groups="g2p_registry_base.group_g2p_admin"
    />
</odoo>
