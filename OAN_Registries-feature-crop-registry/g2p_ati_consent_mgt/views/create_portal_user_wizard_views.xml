<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_g2p_ati_create_portal_user_wizard_form" model="ir.ui.view">
        <field name="name">g2p.ati.create.portal.user.wizard.form</field>
        <field name="model">g2p.ati.create.portal.user.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Portal User">
                <group>
                    <field name="parent_partner_id" />
                    <field name="name" />
                    <field name="login" />
                    <field name="email" />
                    <field name="phone" />
                    <field name="manager_user_id" />
                    <field name="role_ids" widget="many2many_tags" />
                    <field name="can_manage_hierarchy" />
                    <field name="send_reset_password" />
                </group>
                <footer>
                    <button name="action_create_portal_user" string="Create" type="object" class="btn-primary" />
                    <button string="Cancel" special="cancel" />
                </footer>
            </form>
        </field>
    </record>
</odoo>
