<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_g2p_ati_consent_portal_role_tree" model="ir.ui.view">
        <field name="name">g2p.consent.portal.role.tree</field>
        <field name="model">g2p.consent.portal.role</field>
        <field name="arch" type="xml">
            <tree string="Portal Roles">
                <field name="name" />
                <field name="consent_parent_partner_id" />
                <field name="parent_id" />
                <field name="user_count" />
                <field name="create_uid" string="Created By" />
                <field name="create_date" />
                <field name="active" />
            </tree>
        </field>
    </record>

    <record id="view_g2p_ati_consent_portal_role_form" model="ir.ui.view">
        <field name="name">g2p.consent.portal.role.form</field>
        <field name="model">g2p.consent.portal.role</field>
        <field name="arch" type="xml">
            <form string="Portal Role">
                <sheet>
                    <group>
                        <group>
                            <field name="name" required="1" />
                            <field name="consent_parent_partner_id" required="1" />
                            <field name="parent_id" />
                            <field name="active" />
                        </group>
                        <group>
                            <field name="user_count" readonly="1" />
                            <field name="create_uid" string="Created By" readonly="1" />
                            <field name="create_date" readonly="1" />
                            <field name="write_uid" string="Last Updated By" readonly="1" />
                            <field name="write_date" readonly="1" />
                        </group>
                    </group>
                    <group>
                        <field name="description" />
                    </group>
                    <group>
                        <field name="user_ids" widget="many2many_tags" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_g2p_ati_consent_portal_roles" model="ir.actions.act_window">
        <field name="name">Portal Roles</field>
        <field name="res_model">g2p.consent.portal.role</field>
        <field name="view_mode">tree,form</field>
        <field
            name="view_ids"
            eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'tree', 'view_id': ref('g2p_ati_consent_mgt.view_g2p_ati_consent_portal_role_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('g2p_ati_consent_mgt.view_g2p_ati_consent_portal_role_form')})]"
        />
        <field name="groups_id" eval="[(4, ref('base.group_system'))]" />
        <field name="context">{'search_default_active': 1}</field>
    </record>

    <menuitem
        id="menu_g2p_ati_consent_portal_roles"
        name="Portal Roles"
        parent="g2p_ati_consent_mgt.menu_g2p_ati_consent_management_root"
        action="action_g2p_ati_consent_portal_roles"
        sequence="15"
        groups="base.group_system"
    />
</odoo>
