<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_g2p_ati_consent_parent_partner_tree" model="ir.ui.view">
        <field name="name">g2p.ati.consent.parent.partner.tree</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <tree string="Consent Parent Partners">
                <field name="name" />
                <field name="consent_websub_config_id" />
                <field name="email" />
                <field name="phone" />
                <field name="consent_portal_user_count" />
                <field name="active" />
            </tree>
        </field>
    </record>

    <record id="view_g2p_ati_consent_parent_partner_form" model="ir.ui.view">
        <field name="name">g2p.ati.consent.parent.partner.form</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <form string="Consent Parent Partner">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="action_open_consent_portal_users"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-users"
                        >
                            <field name="consent_portal_user_count" string="Portal Users" widget="statinfo" />
                        </button>
                        <button
                            name="action_open_consent_portal_roles"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-sitemap"
                        >
                            <field name="consent_portal_role_count" string="Portal Roles" widget="statinfo" />
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name" required="1" />
                            <field name="consent_websub_config_id" />
                            <field name="allowed_data_field_ids" widget="many2many_tags" />
                            <field name="email" />
                            <field name="phone" />
                        </group>
                        <group>
                            <field name="company_type" />
                            <field name="active" />
                            <field name="is_consent_parent" invisible="1" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Portal Users">
                            <button
                                name="action_open_create_portal_user_wizard"
                                type="object"
                                string="Create Portal User"
                                class="btn-primary"
                            />
                            <field name="consent_portal_user_ids" readonly="1">
                                <tree>
                                    <field name="name" />
                                    <field name="login" />
                                    <field name="consent_portal_manager_user_id" />
                                    <field name="consent_portal_role_ids" widget="many2many_tags" optional="show" />
                                    <field name="consent_portal_can_manage_hierarchy" optional="show" />
                                    <field name="active" />
                                </tree>
                            </field>
                        </page>
                        <page string="Portal Roles">
                            <button
                                name="action_open_consent_portal_roles"
                                type="object"
                                string="Manage Roles"
                                class="btn-secondary"
                            />
                            <field name="consent_portal_role_ids" readonly="1">
                                <tree>
                                    <field name="name" />
                                    <field name="parent_id" />
                                    <field name="user_count" />
                                    <field name="create_uid" string="Created By" />
                                    <field name="create_date" />
                                    <field name="active" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_g2p_ati_consent_portal_users_tree" model="ir.ui.view">
        <field name="name">res.users.tree.consent.portal</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <tree string="Consent Portal Users">
                <field name="name" />
                <field name="login" />
                <field name="consent_parent_partner_id" />
                <field name="consent_portal_manager_user_id" />
                <field name="consent_portal_role_ids" widget="many2many_tags" />
                <field name="consent_portal_can_manage_hierarchy" />
                <field name="active" />
            </tree>
        </field>
    </record>

    <record id="view_g2p_ati_res_users_form_inherit_consent_parent" model="ir.ui.view">
        <field name="name">res.users.form.inherit.consent.parent</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="consent_parent_partner_id" />
                <field name="consent_portal_can_manage_hierarchy" />
                <field name="consent_portal_manager_user_id" />
                <field name="consent_portal_role_ids" widget="many2many_tags" />
            </xpath>
        </field>
    </record>

    <record id="action_g2p_ati_consent_parent_partners" model="ir.actions.act_window">
        <field name="name">Consent Partners</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">tree,form</field>
        <field name="groups_id" eval="[(4, ref('base.group_system'))]" />
        <field name="domain">[('is_consent_parent', '=', True)]</field>
        <field
            name="context"
        >{'default_is_consent_parent': True, 'default_is_company': True, 'default_company_type': 'company'}</field>
        <field
            name="view_ids"
            eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'tree', 'view_id': ref('g2p_ati_consent_mgt.view_g2p_ati_consent_parent_partner_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('g2p_ati_consent_mgt.view_g2p_ati_consent_parent_partner_form')})]"
        />
    </record>

    <record id="action_g2p_ati_consent_portal_users" model="ir.actions.act_window">
        <field name="name">Portal Users</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">tree,form</field>
        <field
            name="view_ids"
            eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'tree', 'view_id': ref('g2p_ati_consent_mgt.view_g2p_ati_consent_portal_users_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('base.view_users_form')})]"
        />
        <field name="groups_id" eval="[(4, ref('base.group_system'))]" />
        <field name="domain">[('consent_parent_partner_id', '!=', False)]</field>
    </record>

    <menuitem
        id="menu_g2p_ati_consent_management_root"
        name="Consent Management"
        sequence="220"
        groups="base.group_system"
    />

    <menuitem
        id="menu_g2p_ati_consent_partners"
        name="Consent Partners"
        parent="menu_g2p_ati_consent_management_root"
        action="action_g2p_ati_consent_parent_partners"
        sequence="10"
        groups="base.group_system"
    />

    <menuitem
        id="menu_g2p_ati_consent_portal_users"
        name="Portal Users"
        parent="menu_g2p_ati_consent_management_root"
        action="action_g2p_ati_consent_portal_users"
        sequence="12"
        groups="base.group_system"
    />
</odoo>
