<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="access_g2p_consent_request_user_xml" model="ir.model.access">
        <field name="name">g2p consent request user</field>
        <field name="model_id" search="[('model', '=', 'g2p.consent.request')]" />
        <field name="group_id" ref="base.group_user" />
        <field name="perm_read" eval="1" />
        <field name="perm_write" eval="1" />
        <field name="perm_create" eval="1" />
        <field name="perm_unlink" eval="0" />
    </record>

    <record id="access_g2p_consent_receipt_user_xml" model="ir.model.access">
        <field name="name">g2p consent receipt user</field>
        <field name="model_id" search="[('model', '=', 'g2p.consent.receipt')]" />
        <field name="group_id" ref="base.group_user" />
        <field name="perm_read" eval="1" />
        <field name="perm_write" eval="1" />
        <field name="perm_create" eval="1" />
        <field name="perm_unlink" eval="0" />
    </record>
</odoo>
