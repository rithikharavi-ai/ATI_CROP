<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template
        id="ati_group_list_template"
        inherit_id="g2p_registration_portal_base.group_list"
        customize_show="True"
        name="farmers"
        priority="200"
    >
        <xpath expr="//div[hasclass('main-container')]" position="replace">
            <div class="main-container1">

                <div class="mx-auto">

                    <div
                        style="max-width: 1400px"
                        class="top-content mx-auto d-flex flex-row justify-content-between align-items-center px-2 py-3"
                    >
                        <div class="d-flex flex-column justify-content-start">
                            <h5
                                style="font: normal 600 15px / 22px Inter !important;"
                                class="all-title"
                            >Household List</h5>

                            <ol class="breadcrumb bg-transparent d-flex flex-col ">
                                <li class="breadcrumb-item">
                                    <a href="/serviceprovider/home">Dashboard</a>
                                </li>
                                <li class="breadcrumb-item active" aria-current="page">Household List</li>
                            </ol>
                        </div>

                            <a t-attf-href="/serviceprovider/group/create/" style="float:right;">
                            <button
                                type="button"
                                data-bs-toggle="tooltip"
                                data-bs-title="Create"
                                class="btn btn-sm py-2 d-flex align-items-center btn-primary create-new"
                                style="
                                row-gap: 4px;"
                            > <span class="create_new mx-1">Create New </span><span class="fa fa-plus" />
                                </button>
                            </a>

                    </div>

                    <div class="list-view">


                        <div
                            class="table-head-container align-items-lg-center py-3  d-flex flex-column flex-lg-row flex-md-wrap justify-content-between px-3 mx-auto "
                        >

                            <div id="head_name_rec">
                                <p class="table-title d-flex flex-row"> Household List - <span
                                        class="count-text"
                                    >&amp;nbsp;<t t-out="len(groups)    " />
                                    Records</span>

                                </p>
                            </div>

                            <div class="additional_filter_container">

                                <div class="additional_filter header_filter">
                                    <select
                                        id="region_selection_group"
                                        class="form-select"
                                        name="region"
                                        required="required"
                                    >
                                        <option value=" ">Region</option>
                                        <t t-foreach="region" t-as="option">
                                            <option t-att-value="option.id">
                                                <t t-esc="option.name" />
                                            </option>
                                        </t>
                                    </select>
                                </div>

                                <div class="additional_filter header_filter">
                                    <select
                                        id="zone_selection_group"
                                        class="form-select"
                                        name="zone"
                                        required="required"
                                    >
                                        <option value=" ">Zone</option>
                                        <t t-foreach="zone" t-as="option">
                                            <option t-att-value="option.id">
                                                <t t-esc="option.name" />
                                            </option>
                                        </t>
                                    </select>
                                </div>

                                <div class="additional_filter header_filter">
                                    <select id="woreda_selection_group" class="form-select" name="woreda">
                                        <option value=" ">Woreda</option>
                                        <t t-foreach="wereda" t-as="option">
                                            <option t-att-value="option.id">
                                                <t t-esc="option.name" />
                                            </option>
                                        </t>
                                    </select>
                                </div>


                                <div class="additional_filter header_filter">
                                    <select id="kebele_selection_group" class="form-select" name="kebele">
                                        <option value=" ">Kebele</option>
                                        <t t-foreach="kebele" t-as="option">
                                            <option t-att-value="option.id">
                                                <t t-esc="option.name" />
                                            </option>
                                        </t>
                                    </select>
                                </div>


                                <form class="form-inline d-flex pb-3 align-items-center">
                                    <div class="search-box">
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="13.6"
                                            height="13.6"
                                            fill="currentColor"
                                            class="bi bi-search search-icon"
                                            viewBox="0 0 16 16"
                                        >
                                            <path
                                                d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"
                                            />
                                        </svg>
                                        <input
                                            placeholder="Search"
                                            class="search-text"
                                            name="q"
                                            id="search-text"
                                        />
                                        <span id="search-text-clear">
                                            <i class="fa fa-times" />
                                        </span>

                                    </div>

                                    <div
                                        id="search-result-count"
                                        style="position:absolute; margin-top: 70px;color: #078148;font-weight:500;font-size: 12px;padding:5px"
                                    >
                                    </div>

                                    <div onclick="showModal()" class="filter-box">
                                    <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="16"
                                            height="16"
                                            fill="currentColor"
                                            class="bi bi-funnel filter-icon"
                                            viewBox="0 0 16 16"
                                        >
                                    <path
                                                d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5zm1 .5v1.308l4.372 4.858A.5.5 0 0 1 7 8.5v5.306l2-.666V8.5a.5.5 0 0 1 .128-.334L13.5 3.308V2z"
                                            />
                                    </svg>
                                    <input
                                            placeholder="Filters"
                                            class="flter-input"
                                            name="f_input"
                                            id="f_input"
                                            readonly="readonly"
                                        />
                                    </div>


                                </form>

                            </div>






                        </div>


                        <div class="tables-values-container px-3">
                            <table id="newreimbursements">
                                <thead class="d-none d-lg-table-header-group">
                                    <tr>
                                        <th class="sr-column" style="color:#b3b3b3;">Sr.No.</th>
                                        <th class="name-column">Name <i class="fa fa-sort" /></th>
                                        <th class="no-column-group">No of Members</th>
                                        <th class="fixed-width-column-group">Region <i
                                                class="fas fa-sort fa-3x"
                                            /></th>
                                        <th class="fixed-width-column-group">Zone <i
                                                class="fas fa-sort fa-3x"
                                            /></th>
                                        <th class="fixed-width-column-group">Woreda <i
                                                class="fas fa-sort fa-3x"
                                            /></th>
                                        <th class="fixed-width-column-group">Kebele <i
                                                class="fas fa-sort fa-2xl"
                                            /></th>
                                        <th
                                            class="fixed-width-column-group last-updated-header"
                                        >Last Updated <i class="fas fa-sort fa-lg" /></th>
                                        <th class="status-column-group">Status <i class="fas fa-sort fa-3x" />
                                        </th>
                                        <th class="status-column-group">Action </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="groups" t-as="group">
                                        <tr class="grid3_table">
                                            <td class="sr-column tr_grid_item1" style="color:#b3b3b3;" />

                                            <td
                                                data-label="Name"
                                                class="name-column tr_grid_item2"
                                                style="color:#078148; font: normal normal 600 13px/16px Inter;"
                                            >
                                                <t t-out="group['name']" />
                                            </td>


                                            <td data-label="Members" class="no-column-group tr_grid_item3">
                                                <t t-out="len(group['group_membership_ids'])" />
                                            </td>

                                            <td
                                                data-label="Region"
                                                class="fixed-width-column-group tr_grid_item4"
                                            >
                                                <t t-out="group['region']['name']" />
                                            </td>


                                            <td
                                                data-label="Zone"
                                                class="fixed-width-column-group tr_grid_item5"
                                            >
                                                <t t-out="group['zone']['name']" />
                                            </td>

                                            <td
                                                data-label="Woreda"
                                                class="fixed-width-column-group tr_grid_item6"
                                            >
                                                <t t-out="group['woreda']['name']" />
                                            </td>

                                            <td
                                                data-label="Kebele"
                                                class="fixed-width-column-group tr_grid_item7"
                                            >
                                                <t t-out="group['kebele']['name']" />
                                            </td>

                                            <td
                                                data-label="Last Update"
                                                class="fixed-width-column tr_grid_item8"
                                            >
                                            <t t-out="group['write_date']" />
                                            </td>

                                            <td data-label="Status" class="status-column-group tr_grid_item9">
                                                <div class="status-icon">
                                                    <button type="object" class="view-button2">
                                                        <t
                                                            t-esc="dict(request.env['res.partner'].fields_get(['state'])['state']['selection'])[group['state']]"
                                                        />
                                                    </button>
                                                </div>
                                            </td>

                                            <td
                                                data-label="Action"
                                                class="status-column-group tr_grid_item10"
                                            >
                                                <a t-attf-href="/serviceprovider/group/update/{{ group.id }}">
                                                    <button
                                                        string="Update"
                                                        type="object"
                                                        class="view-button2"
                                                    >
                                                        Update
                                                    </button>
                                                </a>
                                            </td>

                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>

                        <div id="page-buttons" class="pagination justify-content-center pb-4">
                        </div>

                    </div>

                </div>



    <div class="d-none filter_modal_back " id="filterModal" tabindex="-1" role="dialog">

        <div style="margin: 0 auto !important;" class=" filter_modal px-5 " role="document">

            <div
                            style="background-color: white; border-radius: 1rem; text-align: center;"
                            class=" py-2 modal_container"
                        >

                    <div class="modal-header">
                        <!-- Icon and Title -->
                        <h5 class="modal-title d-flex gap-1 fs-6 align-items-center" id="exampleModalLabel">

                        Filters

                        <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="22"
                                        height="22"
                                        fill="currentColor"
                                        class="bi bi-funnel filter-icon"
                                        viewBox="0 0 16 16"
                                    >
                                                    <path
                                            d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5zm1 .5v1.308l4.372 4.858A.5.5 0 0 1 7 8.5v5.306l2-.666V8.5a.5.5 0 0 1 .128-.334L13.5 3.308V2z"
                                        />
                                                    </svg>
                        </h5>
                </div>



                <div class="additional_filter_container p-1">

                        <div class="modal_filter_container">

                            <div class="additional_filter modal_filter  mf1 ">
                                                    <select
                                            id="region_selection_group_modal"
                                            class="form-select"
                                            name="region"
                                            required="required"
                                        >
                                                        <option value=" ">Region</option>
                                                        <t t-foreach="region" t-as="option">
                                                            <option t-att-value="option.id">
                                                                <t t-esc="option.name" />
                                                            </option>
                                                        </t>
                                                    </select>
                            </div>

                            <div class="additional_filter modal_filter mf2 ">
                                <select
                                            id="zone_selection_group_modal"
                                            class="form-select"
                                            name="zone"
                                            required="required"
                                        >
                                    <option value=" ">Zone</option>
                                    <t t-foreach="zone" t-as="option">
                                        <option t-att-value="option.id">
                                            <t t-esc="option.name" />
                                        </option>
                                    </t>
                                </select>
                            </div>

                            <div class="additional_filter modal_filter mf3">
                                <select id="woreda_selection_group_modal" class="form-select" name="woreda">
                                    <option value=" ">Woreda</option>
                                    <t t-foreach="wereda" t-as="option">
                                        <option t-att-value="option.id">
                                            <t t-esc="option.name" />
                                        </option>
                                    </t>
                                </select>
                            </div>


                            <div class="additional_filter modal_filter mf4">
                                <select id="kebele_selection_group_modal" class="form-select" name="kebele">
                                    <option value=" ">Kebele</option>
                                    <t t-foreach="kebele" t-as="option">
                                        <option t-att-value="option.id">
                                            <t t-esc="option.name" />
                                        </option>
                                    </t>
                                </select>
                            </div>

                        </div>
                             <button
                                    type="button"
                                    onclick="closeModal()"
                                    class="btn btn-sm py-1 mt-4 btn-primary create-new"
                                >Submit</button>

                </div>

           </div>


        </div>



    </div>

    <script>





    function showModal() {
        var modal = document.getElementById('filterModal');
        modal.classList.remove('d-none');
    }


      function closeModal() {
        var modal = document.getElementById('filterModal');
        modal.classList.add('d-none');
    }






    </script>

                <div id="page-buttons" class="pagination justify-content-center">

                </div>
                <script
                    type="text/javascript"
                    src="/g2p_ati_service_provider_portal/static/src/js/table_pagination_and_row.js"
                />


                <link rel="stylesheet" href="/g2p_ati_service_provider_portal/static/src/css/list.css" />

            </div>


        </xpath>
    </template>
</odoo>
