<odoo>
    <template
        id="ati_dashboard_template"
        inherit_id="g2p_agent_portal_base.home_page"
        customize_show="True"
        name="ATI Dashboard"
        priority="200"
    >
        <xpath expr="//div[hasclass('container-adjuster')]" position="replace">
            <div
                class="container-adjuster ati-sp-dashboard-shell"
                style="margin-top: 0; margin-bottom: 100px;"
            >
                <style>
                    .ati-sp-dashboard-shell {
                        margin: 0 auto 100px !important;
                        padding: 3.5rem 1.25rem 0;
                        background: linear-gradient(180deg, #fbfdfb 0%, #f4f8f5 100%);
                    }
                    .ati-sp-dashboard-hero {
                        max-width: 820px;
                        margin: 0 auto 2.6rem;
                        text-align: center;
                    }
                    .ati-sp-dashboard-title {
                        margin: 0;
                        color: #1c2c25;
                        font-size: clamp(2.65rem, 6vw, 4.4rem);
                        font-weight: 800;
                        letter-spacing: -0.04em;
                        line-height: 1.02;
                    }
                    .ati-sp-dashboard-subtitle {
                        max-width: 640px;
                        margin: 1rem auto 0;
                        color: #64756e;
                        font-size: 1.22rem;
                        line-height: 1.6;
                        font-weight: 500;
                    }
                    .ati-sp-dashboard-shell .dashboard-portal-grid {
                        row-gap: 2rem;
                        column-gap: 1.5rem;
                    }
                    .ati-sp-dashboard-shell .dashboard-portal-card {
                        position: relative;
                        overflow: hidden;
                        height: 100%;
                        padding: 1.9rem 1.9rem 1.5rem;
                        border: 1px solid rgba(0, 145, 71, 0.08);
                        border-radius: 28px;
                        background: #ffffff;
                        box-shadow: 0 16px 40px rgba(0, 145, 71, 0.08);
                        transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
                    }
                    .ati-sp-dashboard-shell .dashboard-portal-card:hover {
                        transform: translateY(-6px);
                        box-shadow: 0 22px 46px rgba(0, 145, 71, 0.12);
                        border-color: rgba(0, 145, 71, 0.16);
                    }
                    .ati-sp-dashboard-shell .dashboard-portal-card-accent {
                        position: absolute;
                        top: -52px;
                        right: -52px;
                        width: 148px;
                        height: 148px;
                        border-radius: 50%;
                        background: radial-gradient(circle, rgba(0, 145, 71, 0.08) 0%, rgba(0, 145, 71, 0.08) 58%, rgba(0, 145, 71, 0) 60%);
                        pointer-events: none;
                    }
                    .ati-sp-dashboard-shell .dashboard-portal-card-icon {
                        position: relative;
                        z-index: 1;
                        display: inline-flex;
                        align-items: center;
                        justify-content: center;
                        width: 56px;
                        height: 56px;
                        margin-bottom: 1.7rem;
                        border-radius: 16px;
                        background: rgba(0, 145, 71, 0.12);
                        color: #009147;
                        font-size: 1.35rem;
                        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
                    }
                    .ati-sp-dashboard-shell .dashboard-portal-card-icon img {
                        width: 28px;
                        height: 28px;
                        object-fit: contain;
                        display: block;
                    }
                    .ati-sp-dashboard-shell .dashboard-portal-card-title {
                        position: relative;
                        z-index: 1;
                        margin: 0 0 0.85rem;
                        color: #1c2c25;
                        font-size: 2.1rem;
                        font-weight: 800;
                        letter-spacing: -0.03em;
                    }
                    .ati-sp-dashboard-shell .dashboard-portal-card-description {
                        position: relative;
                        z-index: 1;
                        min-height: 104px;
                        margin: 0 0 1.6rem;
                        color: #61726c;
                        font-size: 1.02rem;
                        line-height: 1.65;
                    }
                    .ati-sp-dashboard-shell .dashboard-portal-card-cta {
                        position: relative;
                        z-index: 1;
                        display: inline-flex;
                        align-items: center;
                        justify-content: center;
                        gap: 0.7rem;
                        width: 100%;
                        min-height: 56px;
                        padding: 0.95rem 1.15rem;
                        border-radius: 999px;
                        font-size: 1rem;
                        font-weight: 700;
                        line-height: 1.35;
                        text-align: center;
                        white-space: normal;
                        text-decoration: none;
                        transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
                    }
                    .ati-sp-dashboard-shell .dashboard-portal-card-cta:hover,
                    .ati-sp-dashboard-shell .dashboard-portal-card-cta:focus {
                        transform: translateY(-1px);
                    }
                    .ati-sp-dashboard-shell .dashboard-portal-card-cta--solid {
                        border: 1px solid rgba(0, 145, 71, 0.18);
                        background: rgba(0, 145, 71, 0.08);
                        color: #17633f;
                        box-shadow: none;
                    }
                    .ati-sp-dashboard-shell .dashboard-portal-card-cta--solid:hover,
                    .ati-sp-dashboard-shell .dashboard-portal-card-cta--solid:focus,
                    .ati-sp-dashboard-shell .dashboard-portal-card-cta--solid:active {
                        color: #ffffff;
                        background: linear-gradient(135deg, #009147 0%, #0a9a57 100%);
                        box-shadow: 0 18px 32px rgba(0, 145, 71, 0.2);
                    }
                    .ati-sp-dashboard-shell .dashboard-portal-card-cta--outline {
                        border: 1px solid rgba(0, 145, 71, 0.18);
                        background: rgba(0, 145, 71, 0.08);
                        color: #17633f;
                    }
                    .ati-sp-dashboard-shell .dashboard-portal-card-cta--outline:hover,
                    .ati-sp-dashboard-shell .dashboard-portal-card-cta--outline:focus,
                    .ati-sp-dashboard-shell .dashboard-portal-card-cta--outline:active {
                        color: #ffffff;
                        background: linear-gradient(135deg, #009147 0%, #0a9a57 100%);
                        border-color: transparent;
                        box-shadow: 0 18px 32px rgba(0, 145, 71, 0.2);
                    }
                    .ati-sp-dashboard-shell .dashboard-portal-card-footer {
                        position: relative;
                        z-index: 1;
                        display: flex;
                        align-items: center;
                        flex-wrap: wrap;
                        gap: 0.9rem;
                        margin-top: 1.4rem;
                    }
                    .ati-sp-dashboard-shell .dashboard-portal-card-avatars {
                        display: inline-flex;
                        align-items: center;
                        padding-left: 0.15rem;
                    }
                    .ati-sp-dashboard-shell .dashboard-portal-card-avatar {
                        display: inline-flex;
                        align-items: center;
                        justify-content: center;
                        width: 28px;
                        height: 28px;
                        margin-left: -0.15rem;
                        border: 2px solid #ffffff;
                        border-radius: 50%;
                        background: linear-gradient(135deg, #0a9a57 0%, #009147 100%);
                        color: #ffffff;
                        font-size: 0.72rem;
                        font-weight: 700;
                        box-shadow: 0 6px 12px rgba(0, 145, 71, 0.14);
                    }
                    .ati-sp-dashboard-shell .dashboard-portal-card-stat {
                        color: #6f817b;
                        font-size: 0.95rem;
                        font-weight: 700;
                    }
                    @media (max-width: 991.98px) {
                        .ati-sp-dashboard-shell {
                            padding-top: 2.8rem;
                        }
                        .ati-sp-dashboard-shell .dashboard-portal-card {
                            padding: 1.65rem 1.45rem 1.35rem;
                        }
                        .ati-sp-dashboard-shell .dashboard-portal-card-title {
                            font-size: 1.85rem;
                        }
                        .ati-sp-dashboard-shell .dashboard-portal-card-description {
                            min-height: 0;
                        }
                    }
                    @media (max-width: 575.98px) {
                        .ati-sp-dashboard-shell {
                            padding: 2.2rem 0.85rem 0;
                        }
                        .ati-sp-dashboard-title {
                            font-size: 2.45rem;
                        }
                        .ati-sp-dashboard-subtitle {
                            font-size: 1rem;
                        }
                        .ati-sp-dashboard-shell .dashboard-portal-card {
                            border-radius: 24px;
                        }
                        .ati-sp-dashboard-shell .dashboard-portal-card-title {
                            font-size: 1.7rem;
                        }
                        .ati-sp-dashboard-shell .dashboard-portal-card-description {
                            font-size: 0.95rem;
                            line-height: 1.55;
                        }
                        .ati-sp-dashboard-shell .dashboard-portal-card-cta {
                            min-height: 0;
                            padding: 0.9rem 1rem;
                            font-size: 0.96rem;
                            gap: 0.5rem;
                        }
                    }
                </style>
                <div class="ati-sp-dashboard-hero">
                    <h1 class="ati-sp-dashboard-title">Registration Portal</h1>
                    <p class="ati-sp-dashboard-subtitle">
                        Register individual farmers and households, manage their records, and continue workflows from one place.
                    </p>
                </div>
                <div class="row justify-content-center dashboard-portal-grid mx-auto" style="max-width: 1200px;">
                    <div class="col-lg-5 col-md-6 col-12">
                        <div class="dashboard-portal-card dashboard-portal-card--farmers">
                            <div class="dashboard-portal-card-accent" aria-hidden="true"></div>
                            <div class="dashboard-portal-card-icon">
                                <img
                                    src="/g2p_ati_service_provider_portal/static/description/farmer.png"
                                    alt="Farmers"
                                />
                            </div>
                            <h5 class="dashboard-portal-card-title">Farmers</h5>
                            <p class="dashboard-portal-card-description">
                                Access farmer records, updates, and registration workflows tailored for ATI field operations.
                            </p>
                            <a href="/serviceprovider/individual" class="dashboard-portal-card-cta dashboard-portal-card-cta--solid">
                                <span>Enter Farmer Portal</span>
                                <i class="fa fa-arrow-right" aria-hidden="true"></i>
                            </a>
                            <div class="dashboard-portal-card-footer">
                                
                                <span class="dashboard-portal-card-stat">
                                    <t t-out="len(individuals)" /> Active Farmers
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-5 col-md-6 col-12">
                        <div class="dashboard-portal-card dashboard-portal-card--households">
                            <div class="dashboard-portal-card-accent" aria-hidden="true"></div>
                            <div class="dashboard-portal-card-icon dashboard-portal-card-icon--soft">
                                <img
                                    src="/g2p_ati_service_provider_portal/static/description/home.png"
                                    alt="Households"
                                />
                            </div>
                            <h5 class="dashboard-portal-card-title">Households</h5>
                            <p class="dashboard-portal-card-description">
                                Manage household groups, linked members, and community registration activity from one place.
                            </p>
                            <a href="/serviceprovider/group" class="dashboard-portal-card-cta dashboard-portal-card-cta--outline">
                                <span>Enter Household Portal</span>
                                <i class="fa fa-arrow-right" aria-hidden="true"></i>
                            </a>
                            <div class="dashboard-portal-card-footer">
                                
                                <span class="dashboard-portal-card-stat">
                                    <t t-out="len(households)" /> Active Households
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <link rel="stylesheet" href="/g2p_ati_service_provider_portal/static/src/css/style.css" />
        </xpath>
    </template>
</odoo>
