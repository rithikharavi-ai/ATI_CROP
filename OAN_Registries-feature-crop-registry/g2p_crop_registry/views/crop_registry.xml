<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <data>

        <!-- Tree View -->
        <record id="view_crop_registry_tree" model="ir.ui.view">
            <field name="name">g2p.crop.registry.tree</field>
            <field name="model">g2p.crop.registry</field>
            <field name="arch" type="xml">
                <tree string="Crop Sown Registry">
                    <field name="farmer_id"
                           context="{'show_farmer_id': True}"
                           options="{'no_create': True}"/>
                    <field name="fyda_id"/>
                    <field name="zone_name_id"/>
                    <field name="crop_name_id"/>
                    <field name="crop_category_id"/>
                    <field name="crop_variety_id"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_g2p_crop_registry_form" model="ir.ui.view">
            <field name="name">g2p.crop.registry.form</field>
            <field name="model">g2p.crop.registry</field>
            <field name="arch" type="xml">
                <form string="Crop Sown Registry">
                    <sheet>
                        <group string="Farmer &amp; Plot Identity">
                            <group>
                                <field name="farmer_id"
                                       context="{'show_farmer_id': True}"
                                       options="{'no_create': True}"/>
                                <field name="fyda_id"/>
                                <field name="farmer_display_id"/>
<!--                                <field name="owner_name"/>-->
                                <field name="land_info_id" options="{'no_create': True}" invisible="not farmer_id" domain="[('farmer_id', '=', farmer_id)]"/>
                                <field name="ownership_type"/>
                                <field name="land_area"/>
                                <field name="land_category"/>
                                <field name="soil_fertility"/>
                                <field name="region_name_id"/>
                                <field name="zone_name_id"/>
                                <field name="woreda_name_id"/>
                                <field name="kebele_id" options="{'no_create': True}"/>
                                <field name="gps"/>
                            </group>
                        <notebook>
<!--                            <page string="Land Details">-->
<!--                                <group>-->
<!--&lt;!&ndash;                                    <field name="land_plan"/>&ndash;&gt;-->
<!--                                    -->
<!--&lt;!&ndash;                                    <field name="current_land_use"/>&ndash;&gt;-->
<!--&lt;!&ndash;                                    <field name="irrigation_type"/>&ndash;&gt;-->
<!--                                </group>-->
<!--                            </page>-->
                            <page string="Crop Information">
                                <group string="Seasonal Crops" invisible="land_category != 'seasonal'">
                                    <field name="seasonal_line_ids" nolabel="1" colspan="2">
                                        <tree>
                                            <field name="season_id" width="11%" class="text-start"/>
                                            <field name="crop_name_id" width="11%" class="text-start"/>
                                            <field name="crop_category_id" width="11%" class="text-start"/>
                                            <field name="crop_variety_id" width="11%" class="text-start"/>
                                            <field name="crop_planned_area" width="11%" class="text-start"/>
                                            <field name="crop_growth_duration" width="11%" class="text-start"/>
                                            <field name="seed_planned" width="11%" class="text-start"/>
                                            <field name="seed_planned_fertilizer_type" width="11%" class="text-start"/>
                                            <field name="water_resource_line_ids" widget="many2many_tags" width="12%" class="text-start"/>
                                        </tree>
                                        <form>
                                            <sheet>
                                                <group string="Season Details">
                                                    <group>
                                                        <field name="season_id" options="{'no_create': True, 'no_open': True}"/>
                                                        <field name="start_gc" readonly="1"/>
                                                        <field name="start_month" readonly="1"/>
                                                        <field name="start_day" readonly="1"/>
                                                    </group>
                                                    <group>
                                                        <field name="end_gc" readonly="1"/>
                                                        <field name="end_month" readonly="1"/>
                                                        <field name="end_day" readonly="1"/>
                                                    </group>
                                                </group>
                                                <group string="Crop Details">
                                                    <group>
                                                        <field name="crop_name_id"/>
                                                        <field name="collected_gc"/>
                                                        <field name="collected_ec"/>
                                                    </group>
                                                    <group>
                                                        <field name="crop_category_id" readonly="1"/>
                                                        <field name="crop_variety_id" domain="[('crop_id', '=', crop_name_id)]"/>
                                                    </group>
                                                </group>
                                                <group string="Crop Planned Inputs">
                                                    <group>
                                                        <field name="crop_growth_duration"/>
                                                        <field name="crop_planned_area"/>
                                                        <field name="crop_expected"/>
                                                    </group>
                                                </group>
                                                <group string="Seed Planned Inputs">
                                                    <group>
                                                        <field name="seed_planned"/>
                                                        <field name="seed_planned_qty"/>
                                                        <field name="seed_planned_fertilizer_type"/>
                                                    </group>
                                                    <group>
                                                        <field name="seed_planned_fertilizer_name" invisible="not seed_planned_fertilizer_type"/>
                                                        <field name="seed_planned_fertilizer_qty"/>
                                                        <field name="seed_planned_fertilizer_sack"/>
                                                    </group>
                                                    <field name="water_resource_line_ids" colspan="2">
                                                        <tree editable="bottom">
                                                            <field name="water_resource_id"/>
                                                            <field name="method_id" options="{'no_create': True}"/>
                                                            <field name="frequency"/>
                                                        </tree>
                                                    </field>
                                                </group>
                                            </sheet>
                                        </form>
                                    </field>
                                </group>
                                <group string="Horticulture Crops" invisible="land_category != 'horticulture'">
                                        <field name="horticulture_line_ids" nolabel="1" colspan="2">
                                        <tree>
                                            <field name="season_id" width="11%" class="text-start"/>
                                            <field name="crop_name_id" width="11%" class="text-start"/>
                                            <field name="crop_category_id" width="11%" class="text-start"/>
                                            <field name="crop_variety_id" width="11%" class="text-start"/>
                                            <field name="crop_planned_area" width="11%" class="text-start"/>
                                            <field name="crop_growth_duration" width="11%" class="text-start"/>
                                            <field name="seed_planned" width="11%" class="text-start"/>
                                            <field name="seed_planned_fertilizer_type" width="11%" class="text-start"/>
                                            <field name="water_resource_line_ids" widget="many2many_tags" width="12%" class="text-start"/>
                                        </tree>
                                        <form>
                                            <sheet>
                                                <group string="Season Details">
                                                    <group>
                                                        <field name="season_id" options="{'no_create': True, 'no_open': True}"/>
                                                        <field name="start_gc" readonly="1"/>
                                                        <field name="start_month" readonly="1"/>
                                                        <field name="start_day" readonly="1"/>
                                                    </group>
                                                    <group>
                                                        <field name="end_gc" readonly="1"/>
                                                        <field name="end_month" readonly="1"/>
                                                        <field name="end_day" readonly="1"/>
                                                    </group>
                                                </group>
                                                <group string="Crop Details">
                                                    <group>
                                                        <field name="crop_name_id"/>
                                                        <field name="collected_gc"/>
                                                        <field name="collected_ec"/>
                                                    </group>
                                                    <group>
                                                        <field name="crop_category_id" readonly="1"/>
                                                        <field name="crop_variety_id" domain="[('crop_id', '=', crop_name_id)]"/>
                                                    </group>
                                                </group>
                                                <group string="Crop Planned Inputs">
                                                    <group>
                                                        <field name="crop_growth_duration"/>
                                                        <field name="crop_planned_area"/>
                                                        <field name="crop_expected"/>
                                                    </group>
                                                </group>
                                                <group string="Seed Planned Inputs">
                                                    <group>
                                                        <field name="seed_planned"/>
                                                        <field name="seed_planned_qty"/>
                                                        <field name="seed_planned_fertilizer_type"/>
                                                    </group>
                                                    <group>
                                                        <field name="seed_planned_fertilizer_name" invisible="not seed_planned_fertilizer_type"/>
                                                        <field name="seed_planned_fertilizer_qty"/>
                                                        <field name="seed_planned_fertilizer_sack"/>
                                                    </group>
                                                    <field name="water_resource_line_ids" colspan="2">
                                                        <tree editable="bottom">
                                                            <field name="water_resource_id"/>
                                                            <field name="method_id" options="{'no_create': True}"/>
                                                            <field name="frequency"/>
                                                        </tree>
                                                    </field>
                                                </group>
                                            </sheet>
                                        </form>
                                    </field>
                                </group>
                            </page>
<page string="Cultivation Details">
                                <group string="Seasonal Crops (Actual)" invisible="land_category != 'seasonal'">
                                    <field name="actual_seasonal_line_ids" nolabel="1" colspan="2">
                                        <tree decoration-danger="is_mismatch" decoration-success="not is_mismatch and crop_name_id">
                                            <field name="season_id" width="11%" class="text-start"/>
                                            <field name="crop_name_id" width="11%" class="text-start"/>
                                            <field name="crop_category_id" width="11%" class="text-start" readonly="1"/>
                                            <field name="crop_variety_id" width="11%" class="text-start" domain="[('crop_id', '=', crop_name_id)]"/>
                                            <field name="actual_crop_area" width="11%" class="text-start"/>
                                            <field name="actual_growth_duration" width="11%" class="text-start"/>
                                            <field name="actual_seed_class" width="11%" class="text-start"/>
                                            <field name="actual_fertilizer_type" width="11%" class="text-start"/>
                                            <field name="water_resource_line_ids" widget="many2many_tags" width="12%" class="text-start"/>
                                            <field name="collected_gc" column_invisible="1"/>
                                            <field name="collected_ec" column_invisible="1"/>
                                            <field name="is_mismatch" column_invisible="1"/>
                                        </tree>
                                        <form>
                                            <sheet>
                                                <group string="Season Details">
                                                    <group>
                                                        <field name="season_id" options="{'no_create': True, 'no_open': True}"/>
                                                        <field name="start_gc" readonly="1"/>
                                                        <field name="start_month" readonly="1"/>
                                                        <field name="start_day" readonly="1"/>
                                                    </group>
                                                    <group>
                                                        <field name="end_gc" readonly="1"/>
                                                        <field name="end_month" readonly="1"/>
                                                        <field name="end_day" readonly="1"/>
                                                    </group>
                                                </group>
                                                <group string="Crop Details">
                                                    <group>
                                                        <field name="crop_name_id"/>
                                                        <field name="collected_gc"/>
                                                        <field name="collected_ec"/>
                                                    </group>
                                                    <group>
                                                        <field name="crop_category_id" readonly="1"/>
                                                        <field name="crop_variety_id" domain="[('crop_id', '=', crop_name_id)]"/>
                                                    </group>
                                                </group>
                                                <group string="Crop Actual Inputs">
                                                    <group>
                                                        <field name="actual_growth_duration"/>
                                                        <field name="actual_crop_area"/>
                                                        <field name="actual_yield"/>
                                                    </group>
                                                    <field name="land_prep_method_ids" colspan="2">
                                                        <tree editable="bottom">
                                                            <field name="prep_method"/>
                                                            <field name="cultivated_hectares"/>
                                                        </tree>
                                                    </field>
                                                </group>
                                                <group string="Seed Actual Inputs">
                                                    <group>
                                                        <field name="actual_seed_class"/>
                                                        <field name="actual_seed_qty"/>
                                                        <field name="actual_fertilizer_type"/>
                                                    </group>
                                                    <group>
                                                        <field name="actual_fertilizer_name" invisible="not actual_fertilizer_type"/>
                                                        <field name="actual_fertilizer_qty"/>
                                                        <field name="actual_fertilizer_sack"/>
                                                    </group>
                                                    <group>
                                                        <field name="pest_occurrence"/>
                                                        <field name="weed_occurrence"/>
                                                    </group>
                                                    <field name="pest_line_ids" invisible="pest_occurrence != 'yes'" colspan="2">
                                                        <tree editable="bottom">
                                                            <field name="pest_type"/>
                                                            <field name="pest_name_id"/>
                                                            <field name="pesticide_method"/>
                                                            <field name="pesticides_type"/>
                                                            <field name="pesticide_name_id"/>
                                                            <field name="pesticide_frequency"/>
                                                        </tree>
                                                    </field>
                                                    <field name="weed_line_ids" invisible="weed_occurrence != 'yes'" colspan="2">
                                                        <tree editable="bottom">
                                                            <field name="weed_type"/>
                                                            <field name="weed_name_id"/>
                                                            <field name="pesticide_method"/>
                                                            <field name="weedicide_type"/>
                                                            <field name="weedicide_name_id"/>
                                                            <field name="pesticide_frequency"/>
                                                        </tree>
                                                    </field>
                                                    <field name="water_resource_line_ids" colspan="2">
                                                        <tree editable="bottom">
                                                            <field name="water_resource_id"/>
                                                            <field name="method_id" options="{'no_create': True}"/>
                                                            <field name="frequency"/>
                                                        </tree>
                                                    </field>
                                                </group>
                                            </sheet>
                                        </form>
                                    </field>
                                </group>
                                <group string="Horticulture Crops" invisible="land_category != 'horticulture'">
                                    <field name="actual_horticulture_line_ids" nolabel="1" colspan="2">
                                        <tree decoration-danger="is_mismatch" decoration-success="not is_mismatch and crop_name_id">
                                            <field name="season_id" width="11%" class="text-start"/>
                                            <field name="crop_name_id" width="11%" class="text-start"/>
                                            <field name="crop_category_id" width="11%" class="text-start" readonly="1"/>
                                            <field name="crop_variety_id" width="11%" class="text-start" domain="[('crop_id', '=', crop_name_id)]"/>
                                            <field name="actual_crop_area" width="11%" class="text-start"/>
                                            <field name="actual_growth_duration" width="11%" class="text-start"/>
                                            <field name="actual_seed_class" width="11%" class="text-start"/>
                                            <field name="actual_fertilizer_type" width="11%" class="text-start"/>
                                            <field name="water_resource_line_ids" widget="many2many_tags" width="12%" class="text-start"/>
                                            <field name="collected_gc" column_invisible="1"/>
                                            <field name="collected_ec" column_invisible="1"/>
                                            <field name="is_mismatch" column_invisible="1"/>
                                        </tree>
                                        <form>
                                            <sheet>
                                                <group string="Season Details">
                                                    <group>
                                                        <field name="season_id" options="{'no_create': True, 'no_open': True}"/>
                                                        <field name="start_gc" readonly="1"/>
                                                        <field name="start_month" readonly="1"/>
                                                        <field name="start_day" readonly="1"/>
                                                    </group>
                                                    <group>
                                                        <field name="end_gc" readonly="1"/>
                                                        <field name="end_month" readonly="1"/>
                                                        <field name="end_day" readonly="1"/>
                                                    </group>
                                                </group>
                                                <group string="Crop Details">
                                                    <group>
                                                        <field name="crop_name_id"/>
                                                        <field name="collected_gc"/>
                                                        <field name="collected_ec"/>
                                                    </group>
                                                    <group>
                                                        <field name="crop_category_id" readonly="1"/>
                                                        <field name="crop_variety_id" domain="[('crop_id', '=', crop_name_id)]"/>
                                                    </group>
                                                </group>
                                                <group string="Crop Actual Inputs">
                                                    <group>
                                                        <field name="actual_growth_duration"/>
                                                        <field name="actual_crop_area"/>
                                                        <field name="actual_yield"/>
                                                    </group>
                                                    <field name="land_prep_method_ids" colspan="2">
                                                        <tree editable="bottom">
                                                            <field name="prep_method"/>
                                                            <field name="cultivated_hectares"/>
                                                        </tree>
                                                    </field>
                                                </group>
                                                <group string="Seed Actual Inputs">
                                                    <group>
                                                        <field name="actual_seed_class"/>
                                                        <field name="actual_seed_qty"/>
                                                        <field name="actual_fertilizer_type"/>
                                                    </group>
                                                    <group>
                                                        <field name="actual_fertilizer_name" invisible="not actual_fertilizer_type"/>
                                                        <field name="actual_fertilizer_qty"/>
                                                        <field name="actual_fertilizer_sack"/>
                                                    </group>
                                                    <group>
                                                        <field name="pest_occurrence"/>
                                                        <field name="weed_occurrence"/>
                                                    </group>
                                                    <field name="pest_line_ids" invisible="pest_occurrence != 'yes'" colspan="2">
                                                        <tree editable="bottom">
                                                            <field name="pest_type"/>
                                                            <field name="pest_name_id"/>
                                                            <field name="pesticide_method"/>
                                                            <field name="pesticides_type"/>
                                                            <field name="pesticide_name_id"/>
                                                            <field name="pesticide_frequency"/>
                                                        </tree>
                                                    </field>
                                                    <field name="weed_line_ids" invisible="weed_occurrence != 'yes'" colspan="2">
                                                        <tree editable="bottom">
                                                            <field name="weed_type"/>
                                                            <field name="weed_name_id"/>
                                                            <field name="pesticide_method"/>
                                                            <field name="weedicide_type"/>
                                                            <field name="weedicide_name_id"/>
                                                            <field name="pesticide_frequency"/>
                                                        </tree>
                                                    </field>
                                                    <field name="water_resource_line_ids" colspan="2">
                                                        <tree editable="bottom">
                                                            <field name="water_resource_id"/>
                                                            <field name="method_id" options="{'no_create': True}"/>
                                                            <field name="frequency"/>
                                                        </tree>
                                                    </field>
                                                </group>
                                            </sheet>
                                        </form>
                                    </field>
                                </group>

                            </page>
<page string="Cluster Information">
                                <group>
                                    <field name="cluster_plan"/>
                                    <field name="cluster_collected_land"/>
                                    <field name="cluster_collected_quintal"/>
                                    <field name="cluster_participant_farmers"/>
                                    <field name="collected_land"/>
                                    <field name="collected_land_quintal"/>
                                    <field name="collected_by_combiner"/>
                                </group>
                            </page>
<page string="Production Details">
                                <field name="production_detail_ids" nolabel="1">
                                    <form>
                                        <sheet>
                                            <!-- SOWING -->
                                            <group string="Sowing">
                                                <group>
                                                    <field name="season_id"/>
                                                    <field name="sowing_status"/>
                                                    <field name="cluster_status"/>
                                                    <field name="actual_sowing_date"/>
                                                </group>
                                                <group>
                                                    <field name="sown_area"/>
                                                    <field name="sown_by_tractor"/>
                                                    <field name="mechanization_rate_sowing" readonly="1"/>
                                                </group>
                                            </group>

                                            <!-- HARVEST – visible only when sowing_status = sown -->
                                            <group string="Harvest" invisible="sowing_status != 'sown'">
                                                <group>
                                                    <field name="crop_maturity_status"
                                                           decoration-success="crop_maturity_status == 'green'"
                                                           decoration-warning="crop_maturity_status == 'yellow'"/>
                                                    <field name="harvest_date"/>
                                                    <field name="area_harvested"/>
                                                    <field name="qty_harvested"/>
                                                </group>
                                                <group>
                                                    <field name="post_harvest_loss_pct"/>
                                                    <field name="qty_stored"/>
                                                    <field name="qty_sold"/>
                                                </group>
                                            </group>

                                            <!-- HARVEST METHOD -->
                                            <group string="Harvest Method" invisible="sowing_status != 'sown'">
                                                <field name="harvest_method"/>
                                                <field name="harvest_method_area" invisible="not harvest_method"/>
                                            </group>

                                            <!-- PRODUCTION RESULT -->
                                            <group string="Production Result (Computed)" invisible="sowing_status != 'sown'">
                                                <group>
                                                    <field name="yield_per_ha" readonly="1"/>
                                                    <field name="yield_performance_pct" readonly="1"/>
                                                </group>
                                                <group>
                                                    <field name="land_utilization_rate" readonly="1"/>
                                                    <field name="seed_productivity" readonly="1"/>
                                                </group>
                                            </group>
                                        </sheet>
                                    </form>
                                    <tree>
                                        <field name="season_id"/>
                                        <field name="sowing_status"/>
                                        <field name="cluster_status"/>
                                        <field name="sown_area"/>
                                        <field name="actual_sowing_date"/>
                                        <field name="qty_harvested"/>
                                        <field name="yield_per_ha"/>
                                    </tree>
                                </field>
                            </page>
<page string="Survey Personnel">
                                <group>
                                    <field name="surveyor_name"/>
                                    <field name="surveyor_mobile_number"/>
                                    <field name="supervisor_name"/>
                                    <field name="supervisor_mobile_number"/>
                                    <field name="first_approvel_status"/>

                                </group>
                            </page>
<page string="Farmers Required">
                                <group>
                                    <field name="male_farmers"/>
                                    <field name="female_farmers"/>
                                    <field name="total_farmers"/>
                                </group>
                            </page>
<page string="Live Stock Information">
                                <field name="livestock_ids" nolabel="1">
                                    <tree editable="bottom" class="custom_livestock_tree">
                                        <field name="livestock_types_id" string="Live Stock Type" width="33%" class="text-start"/>
                                        <field name="livestock_count" string="Live Stock Number" width="33%" class="text-start"/>
                                        <field name="water_source" string="Livestock Water Source" width="34%" class="text-start"/>
                                    </tree>
                                    <form>
                                        <sheet>
                                            <group>
                                                <field name="livestock_types_id" string="Live Stock Type"/>
                                                <field name="livestock_count" string="Live Stock Number"/>
                                                <field name="water_source" string="Livestock Water Source"/>
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                            </page>
                        
                        </notebook>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_g2p_crop_registry_search" model="ir.ui.view">
            <field name="name">g2p.crop.registry.search</field>
            <field name="model">g2p.crop.registry</field>
            <field name="arch" type="xml">
                <search string="Search Crop Sown Registry">

                    <!-- Search Fields -->
<!--                    <field name="farmer_display_id"/>-->
                    <field name="zone_name_id"/>
                    <field name="woreda_name_id"/>
                    <field name="kebele_id"/>
                    <field name="land_info_id"/>
<!--                    <field name="owner_name"/>-->
                    <field name="crop_name_id"/>
                    <field name="crop_season_ids"/>

                    <!-- Filters -->
                    <filter string="Approved Level 1"
                            name="first_approved"
                            domain="[('first_approvel_status', '=', True)]"/>


                    <!-- Group By -->
                    <group expand="0" string="Group By">

                        <filter string="Zone"
                                name="group_by_zone"
                                context="{'group_by':'zone_name_id'}"/>

                        <filter string="Woreda"
                                name="group_by_woreda"
                                context="{'group_by':'woreda_name_id'}"/>

                        <filter string="Crop"
                                name="group_by_crop"
                                context="{'group_by':'crop_name_id'}"/>



                    </group>

                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_g2p_crop_registry" model="ir.actions.act_window">
            <field name="name">Crop Sown Registry</field>
            <field name="res_model">g2p.crop.registry</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_g2p_crop_registry_search"/>
        </record>

        <!-- Menu -->
        <menuitem id="g2p_crop_registry_menu_item_id"
                  name="Crop Sown Registry"
        />

        <menuitem
                id="menu_gn_division"
                name="Crop Sown Registry"
                parent="g2p_crop_registry_menu_item_id"
                action="action_g2p_crop_registry"
                sequence="6"
        />


        <record id="view_g2p_fertilizer_tree" model="ir.ui.view">
            <field name="name">g2p.fertilizer.tree</field>
            <field name="model">g2p.fertilizer</field>
            <field name="arch" type="xml">
