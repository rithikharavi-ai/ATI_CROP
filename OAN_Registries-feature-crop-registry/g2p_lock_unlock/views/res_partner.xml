<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
   <record id="view_registrant_update_request_form_individual" model="ir.ui.view">
        <field name="name">view_registrant_update_request_form_individual</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="g2p_registry_individual.view_individuals_form" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='other']" position="after">
                <page string="Update Requests" name="update_requests">
                    <field name="update_request_ids" nolabel="1" colspan="2">
                        <tree>
                            <field name="partner_id" />
                            <field name="update_message" string="Changes" />
                            <field name="validator" />
                            <field name="state" />
                            <button
                                title="Approve"
                                icon="fa-check"
                                name="approve_changes"
                                type="object"
                                class="btn btn-success"
                                invisible="state != 'pending'"
                            />
                            <button
                                title="Reject"
                                icon="fa-times"
                                name="reject_changes"
                                type="object"
                                class="btn btn-danger"
                                invisible="state != 'pending'"
                            />
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_registrant_update_requests_form_group" model="ir.ui.view">
        <field name="name">view_registrant_update_requests_form_group</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="g2p_registry_group.view_groups_form" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='other']" position="after">
                <page string="Update Requests" name="update_requests">
                    <field name="update_request_ids" nolabel="1" colspan="2">
                        <tree default_order="id desc">
                            <field name="partner_id" />
                            <field name="update_message" string="Changes" />
                            <field name="validator" />
                            <field name="state" />
                            <button
                                title="Approve"
                                icon="fa-check"
                                name="approve_changes"
                                type="object"
                                class="btn btn-success"
                                invisible="state != 'pending'"
                            />
                            <button
                                title="Reject"
                                icon="fa-times"
                                name="reject_changes"
                                type="object"
                                class="btn btn-danger"
                                invisible="state != 'pending'"
                            />
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_registrant_edit_suggestions_form_individual" model="ir.ui.view">
        <field name="name">view_registrant_edit_suggestions_form_individual</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="g2p_registry_individual.view_individuals_form" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='other']" position="after">
                <page string="Edit Suggestions" name="edit_suggestions">
                    <field name="edit_suggestion_ids" nolabel="1" colspan="2">
                        <tree>
                            <field name="record_id" />
                            <field name="requester_id" />
                            <field name="status" />
                            <field name="type" />
                            <field name="reason" />
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_registrant_edit_suggestions_form_group" model="ir.ui.view">
        <field name="name">view_registrant_edit_suggestions_form_group</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="g2p_registry_group.view_groups_form" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='other']" position="after">
                <page string="Edit Suggestions" name="edit_suggestions">
                    <field name="edit_suggestion_ids" nolabel="1" colspan="2">
                        <tree default_order="id desc">
                            <field name="record_id" />
                            <field name="requester_id" />
                            <field name="status" />
                            <field name="type" />
                            <field name="reason" />
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
