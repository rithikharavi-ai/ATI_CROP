<odoo>

    <record id="view_res_partner_form_inherit" model="ir.ui.view">
        <field name="name">res.partner.form.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <field name="email" position="after">
                <field name="approval_status" />
            </field>
        </field>
    </record>

<record id="view_res_partner_change_request_form" model="ir.ui.view">
    <field name="name">res.partner.change.request.form</field>
    <field name="model">res.partner.change.request</field>
    <field name="arch" type="xml">
        <form string="Change Request">
            <header>
                <button
                        string="Approve"
                        type="object"
                        name="approve_changes"
                        class="btn-primary"
                        invisible="state != 'pending'"
                    />
                <button
                        string="Reject"
                        type="object"
                        name="reject_changes"
                        class="btn-secondary"
                        invisible="state != 'pending'"
                    />
            </header>
            <sheet>
                <group>
                    <field name="requested_by" readonly="1" />
                    <field
                            name="partner_id"
                            readonly="1"
                            string="Changed Record"
                            context="{'form_view_ref': 'g2p_registry_individual.view_individuals_form'}"
                        />

                    <!-- <field name="new_values" /> -->
<!--                    <field name="update_message" string="Changes" widget="html"/>-->
                    <field name="validator" readonly="1" />
                    <field name="state" readonly="1" />
                </group>
            </sheet>

        </form>
    </field>
</record>

<record id="view_res_partner_change_request_tree" model="ir.ui.view">
    <field name="name">res.partner.change.request.tree</field>
    <field name="model">res.partner.change.request</field>
    <field name="arch" type="xml">
        <tree class="text-left">
                <field name="requested_by" readonly="1" />
                <field
                    name="partner_id"
                    readonly="1"
                    string="Changed Record"
                    context="{'form_view_ref': 'g2p_registry_individual.view_individuals_form'}"
                />
<!--                <field name="update_message" string="Changes" readonly="1"/>-->
                <field name="validator" readonly="1" />
                <field name="state" readonly="1" />
                <button
                    title="Approve"
                    icon="fa-check"
                    name="approve_changes"
                    type="object"
                    class="btn btn-success"
                    invisible="state != 'pending'"
                />
                <button
                    title="Reject"
                    icon="fa-times"
                    name="reject_changes"
                    type="object"
                    class="btn btn-danger"
                    invisible="state != 'pending'"
                />

        </tree>
    </field>
</record>

   <record id="edit_request_action" model="ir.actions.act_window">
        <field name="name">Update Request</field>
        <field name="res_model">res.partner.change.request</field>
        <field name="view_mode">tree,form</field>
    </record>

<menuitem
        id="edit_request_menu"
        name="Update Requests"
        action="edit_request_action"
        sequence="100000"
        parent="g2p_registry_base.g2p_main_menu_root"
    />

</odoo>
