<odoo>
    <!-- Tree View -->
    <record id="view_imported_record_tree" model="ir.ui.view">
        <field name="name">g2p.imported.record.tree</field>
        <field name="model">g2p.imported.record</field>
        <field name="arch" type="xml">
            <tree>
                  <header>
                    <button
                        name="assign_records"
                        type="object"
                        string="Assign"
                        class="btn-primary"
                        groups="g2p_draft_publish.group_int_approver,g2p_draft_publish.group_int_admin"
                    />
                </header>
                <field name="given_name" />
                <field name="family_name" />
                <field name="gf_name_eng" />
                <field name="phone" />
                <field name="gender" />
                <field name="region" />
                <field
                    name="draft_status"
                    widget="badge"
                    decoration-success="draft_status == 'draft_created'"
                    decoration-warning="draft_status == 'no_draft'"
                />
                <field name="draft_creator_id" class="text-success fw-semibold" />
                <field name="source_db_ids" widget="many2many_tags" options="{'color_field': 'color'}" />
            </tree>
        </field>
    </record>

    <record id="view_g2p_partner_kanban" model="ir.ui.view">
        <field name="name">g2p.imported.record</field>
        <field name="model">g2p.imported.record</field>
        <field name="arch" type="xml">

            <kanban class="o_kanban_small_column">
                <field name="name" />
                <field name="phone" />
                <field name="source_db_ids" />
                <field name="draft_creator_id" class="text-success fw-semibold" />
                <templates>

                    <t t-name="kanban-box">
                        <div t-attf-class="my-2 oe_kanban_global_click o_kanban_card">
                            <div class="o_kanban_details d-flex flex-column">
                                <div class="d-flex justify-content-between">
                                    <strong>
                                        <field name="name" />
                                    </strong>
                                    <div class="">
                                        <field
                                            decoration-warning="state == 'draft'"
                                            decoration-success="state == 'moved'"
                                            widget="badge"
                                            name="state"
                                        />
                                    </div>
                                </div>
                                <div>
                                    <field name="phone" />
                                </div>
                                <div class="mt-2">
                                    <field name="source_db_ids" widget="many2many_tags" options="{'color_field': 'color'}" />
                                </div>
                                <div class="mt-2">
                                    <span class="text-success fw-semibold">Created by: </span>
                                    <field name="draft_creator_id" class="text-success fw-semibold" />
                                </div>
                                <div class="d-flex justify-content-between mt-2">
                                    <div class="fw-bold">
                                        <field name="record_type" />
                                    </div>
                                    <div class="fw-bold">
                                        <field
                                            style="width: 80px; height: 40px; border: 1px solid rgba(0, 0, 255, 0.2); border-radius: 12%; padding: 4px 12px;"
                                            name="record_from"
                                        />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_imported_record_form" model="ir.ui.view">
        <field name="name">g2p.imported.record.form</field>
        <field name="model">g2p.imported.record</field>
        <field name="arch" type="xml">
            <form string="Imported Record">
                <header>
                    <button
                        name="action_view_draft_records"
                        type="object"
                        string="Open Draft"
                        class="oe_stat_button"
                        invisible="state!='moved'"
                        icon="fa-pencil"
                    />
                    <button
                        name="create_draft_imported_record"
                        type="object"
                        string="Create Draft"
                        invisible="state!='draft'"
                        class="btn btn-info"
                    />
                    <button
                        name="action_to_draft"
                        type="object"
                        string="Remove Draft"
                        invisible="state!='moved'"
                        class="btn btn-warning"
                    />
                    <field name="state" widget="statusbar" statusbar_visible="draft,moved" />
                </header>
                <sheet>
                    <div class="oe_title mb24">
                        <h1>
                            <field
                                id="individual"
                                options="{'line_breaks': False}"
                                widget="text"
                                class="text-break"
                                name="name"
                                default_focus="1"
                            />
                        </h1>
                    </div>
                    <group>
                        <field name="given_name" />
                        <field name="family_name" />
                        <field name="gf_name_eng" />
                    </group>
                    <group>
                    <group>
                        <field name="phone" />
                        <field name="gender" />
                    </group>

                    <group>
                        <field name="region" />
                    </group>

                    <group>
                        <field name="source_db_ids" widget="many2many_tags" options="{'color_field': 'color'}" />
                    </group>

                        <group cols="2" colspan="2">

                            <group>

                                <field name="assigned_region" widget="many2many_tags"
                                />

                            </group>
                                
                       

                            <group>
                            <field name="assigned_languages" 
                           
                            widget="many2many_tags"

                                />

                                
                            </group>
                        </group>
 





                    </group>
                </sheet>

                <div class="oe_chatter">
                    <field
                        name="message_follower_ids"
                        widget="mail_followers"
                        options="{'post_refresh':True}"
                        groups="base.group_system"
                    />
                    <field name="activity_ids" widget="mail_activity" />
                    <field name="message_ids" widget="mail_thread" />
                </div>
            </form>
        </field>
    </record>


    <record id="imported_set_to_draft_view_message_form" model="ir.ui.view">
        <field name="name">message.form</field>
        <field name="model">g2p.imported.record</field>
        <field name="arch" type="xml">
            <form string="Message" nolabel="1" width="300">
                <div class="oe_button_box">
                    <div>
                        <span
                            class="oe_title"
                        >Any Draft Associated with this imported record has been deleted and state has been set to draft.</span>
                    </div>
                </div>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="view_imported_record_search" model="ir.ui.view">
        <field name="name">g2p.imported.record.search</field>
        <field name="model">g2p.imported.record</field>
        <field name="arch" type="xml">
            <search string="Imported Records">
                <field name="name" />
                <field name="phone" />
                <field name="assigned_region" widget="many2many_tags" />
                <field name="assigned_languages" />
                <filter
                    name="draft_created"
                    string="Draft Created"
                    domain="[('draft_status', '=', 'draft_created')]"
                />
              
     <filter 
    name="no_draft" 
    string="No Draft" 
    domain="['|', ('draft_status', '=', 'no_draft'), ('draft_status', '=', '')]" 
/>
                <group expand="0" string="Group By">
                    <filter
                        name="group_by_draft_status"
                        string="Draft Status"
                        context="{'group_by': 'draft_status'}"
                    />
                    <filter
                        name="group_by_region"
                        string="Region"
                        context="{'group_by': 'assigned_region'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <record id="action_imported_record" model="ir.actions.act_window">
        <field name="name">Imported</field>
        <field name="res_model">g2p.imported.record</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="search_view_id" ref="view_imported_record_search" />
        <field name="context">{'search_default_no_draft': 1}</field>
    </record>


    <!-- Menu -->
    <menuitem
        id="menu_imported_record"
        name="Imported"
        parent="g2p_draft_publish.draft_publish_main_menu"
        action="action_imported_record"
        sequence="1"
    />

    <record id="g2p_draft_publish.draft_publish_main_menu" model="ir.ui.menu">
        <field name="name">Imported Records</field>
        <field name="action" ref="action_imported_record" />
        <field name="web_icon">g2p_ati_integrations,static/description/import.png</field>
    </record>



</odoo>
