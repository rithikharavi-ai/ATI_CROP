<odoo>


        <record id="view_imported_record_tree" model="ir.ui.view">
        <field name="name">g2p.imported.record.tree</field>
        <field name="model">g2p.imported.record</field>
        <field name="arch" type="xml">
            <tree>
                  <header>
                    <button name="assign_records" type="object" string="Assign" class="btn-primary" />
                </header>
                <field name="given_name" />
                <field name="family_name" />
                <field name="gf_name_eng" />
                <field name="phone" />
                <field name="gender" />
                <field name="region" />
                <field name="zone" />
                <field name="woreda" />
                <field name="kebele" />
            </tree>
        </field>
    </record>


    <record id="view_imported_record_form" model="ir.ui.view">
        <field name="name">g2p.imported.record.form</field>
        <field name="model">g2p.imported.record</field>
        <field name="arch" type="xml">
            <form string="Imported Record">
                <header>
                    <button
                        name="action_view_draft_records"
                        type="object"
                        string="Open Draft"
                        class="oe_stat_button"
                        invisible="state!='moved'"
                        icon="fa-pencil"
                    />
                    <button
                        name="create_draft_imported_record"
                        type="object"
                        string="Create Draft"
                        invisible="state!='draft'"
                        class="btn btn-info"
                    />
                    <button
                        name="action_to_draft"
                        type="object"
                        string="Remove Draft"
                        invisible="state!='moved'"
                        class="btn btn-warning"
                    />
                    <field name="state" widget="statusbar" statusbar_visible="draft,moved" />
                </header>
                <sheet>
                    <div class="oe_title mb24">
                        <h1>
                            <field
                                id="individual"
                                options="{'line_breaks': False}"
                                widget="text"
                                class="text-break fs-bold text-primary"
                                readonly="1"
                                name="name"
                                default_focus="1"
                            />
                        </h1>
                    </div>
                    <group>
                        <field name="given_name" />
                        <field name="family_name" />
                        <field name="gf_name_eng" />
                    </group>
                    <group>
                    <group>
                        <field name="phone" />
                        <field name="gender" />
                         <field name="region" />
                        <field name="zone" />
                        <field name="woreda" />
                        <field name="kebele" />
                    </group>
                    <group>
                        <field name="region" />
                    </group>
                    </group>
                </sheet>

                <div class="oe_chatter">
                    <field
                        name="message_follower_ids"
                        widget="mail_followers"
                        options="{'post_refresh':True}"
                        groups="base.group_system"
                    />
                    <field name="activity_ids" widget="mail_activity" />
                    <field name="message_ids" widget="mail_thread" />
                </div>
            </form>
        </field>
    </record>



</odoo>
