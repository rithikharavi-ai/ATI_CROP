<odoo>

<record id="g2p_view_g2p_land_info_tree_integration" model="ir.ui.view">
    <field name="model">g2p.land.information</field>
    <field name="name">land.tree inherited</field>
    <field name="inherit_id" ref="g2p_ati.view_g2p_land_info_tree"/>
    <field name="type">tree</field>
    <field name="arch" type="xml">
        <xpath expr="//field[@name='land_certificate']" position="after">
            <field name="integration_status"/>
            
        </xpath>
    </field>
</record>
</odoo>
