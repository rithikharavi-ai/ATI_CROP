<?xml version="1.0" encoding="utf-8" ?>
<odoo>

  <record id="rejection_form_wizard_view" model="ir.ui.view">
    <field name="name">draft.record.form</field>
    <field name="model">draft.record</field>
    <field name="arch" type="xml">
        <form>
            <group>
                <field name="rejection_reason" />
            </group>

            <footer>
                <button name="action_reject" string="Reject" type="object" />
            </footer>
        </form>
    </field>
</record>


<record id="assign_records_wizard_view" model="ir.ui.view">
        <field name="name">assign.records.wizard.form</field>
        <field name="model">assign.records.wizard</field>
        <field name="arch" type="xml">
        <form>
            <group>
                <field name="assigned_region" required="1" widget="many2many_tags" />
                <field name="language_skills"  required="1" widget="many2many_tags" />
            </group>
             <footer>
                    <button
                        name="assign_groups"
                        string="Assign Follower's"
                        type="object"
                        class="btn btn-primary"
                    />
                      <button string="Cancel" class="btn-secondary" special="cancel" />
                </footer>
        </form>
    </field>
</record>

<record id="assign_records_wizard_action" model="ir.actions.act_window">
    <field name="name">Assign Records</field>
    <field name="res_model">assign.records.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
</record>

</odoo>
