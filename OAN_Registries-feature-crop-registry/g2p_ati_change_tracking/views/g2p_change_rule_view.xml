<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_g2p_ati_change_tracking_rule_tree" model="ir.ui.view">
        <field name="name">g2p.change.log.rule.tree</field>
        <field name="model">g2p.change.log.rule</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="model_id"/>
                <field name="log_type"/>
                <field name="log_create"/>
                <field name="log_write"/>
                <field name="log_unlink"/>
                <field name="log_read"/>
            </tree>
        </field>
    </record>

    <record id="view_g2p_ati_change_tracking_rule_form" model="ir.ui.view">
        <field name="name">g2p.change.log.rule.form</field>
        <field name="model">g2p.change.log.rule</field>
        <field name="arch" type="xml">
            <form string="Change Log Rule">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                    <group>
                        <field name="model_id"/>
                        <field name="model_name" readonly="1"/>
                        <field name="model_model" readonly="1"/>
                    </group>
                    <group string="Log Options" col="4">
                        <field name="log_create"/>
                        <field name="log_write"/>
                        <field name="log_unlink"/>
                        <field name="log_read"/>
                        <field name="log_type"/>
                    </group>
                    <footer>
                        <button string="Close" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_g2p_ati_change_tracking_rule_search" model="ir.ui.view">
        <field name="name">g2p.change.log.rule.search</field>
        <field name="model">g2p.change.log.rule</field>
        <field name="arch" type="xml">
            <search string="Change Log Rules">
                <field name="name"/>
                <field name="model_id"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_g2p_ati_change_tracking_rule" model="ir.actions.act_window">
        <field name="name">Change Log Rules</field>
        <field name="res_model">g2p.change.log.rule</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_g2p_ati_change_tracking_rule_search"/>
    </record>

    <!-- Menu -->
    <menuitem id="menu_g2p_ati_change_tracking_rule"
              name="Configuration"
              parent="g2p_ati_change_tracking.menu_g2p_ati_change_tracking_root"
              action="action_g2p_ati_change_tracking_rule"
              sequence="50"
              groups="g2p_ati_change_tracking.group_g2p_ati_change_tracking_manager"/>
</odoo>
