<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_g2p_ati_change_tracking_view_tree" model="ir.ui.view">
        <field name="name">g2p.change.log.view.tree</field>
        <field name="model">g2p.change.log.view</field>
        <field name="arch" type="xml">
            <tree string="Audit Logs (External DB)" create="false">
                <field name="create_date"/>
                <field name="name"/>
                <field name="model_id"/>
                <field name="res_id"/>
                <field name="method"/>
                <field name="user_id"/>
            </tree>
        </field>
    </record>

    <record id="view_g2p_ati_change_tracking_view_form" model="ir.ui.view">
        <field name="name">g2p.change.log.view.form</field>
        <field name="model">g2p.change.log.view</field>
        <field name="arch" type="xml">
            <form string="Change Log (External DB)">
                <sheet>
                    <group string="Log">
                        <group colspan="1">
                            <field name="create_date" readonly="1" string="Changed At"/>
                            <field name="user_id" readonly="1"/>
                            <field name="method" readonly="1"/>
                            <field name="log_type" readonly="1"/>
                        </group>
                        <group colspan="1">
                            <field name="model_id" readonly="1"/>
                            <field name="model_name" invisible="model_id != False" readonly="1"/>
                            <field name="model_model" invisible="model_id != False" readonly="1"/>
                            <field name="res_id" readonly="1"/>
                            <field name="name" readonly="1"/>
                        </group>
                    </group>
                    <!-- <group string="HTTP Context">
                        <field name="http_session_id"/>
                        <field name="http_request_id"/>
                    </group> -->
                    <notebook>
                        <page string="Change Log Lines">
                            <field name="line_ids" readonly="1">
                                <tree string="Log Lines" create="false" edit="false">
                                    <field name="field_id"/>
                                    <field name="field_name"/>
                                    <field name="field_description"/>
                                    <field name="old_value_text" string="Previous"/>
                                    <field name="new_value_text" string="Changed To"/>
                                    <field name="create_date" string="Changed At"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_g2p_ati_change_tracking_view_search" model="ir.ui.view">
        <field name="name">g2p.change.log.view.search</field>
        <field name="model">g2p.change.log.view</field>
        <field name="arch" type="xml">
            <search string="Logs">
                <field name="name"/>
                <field name="model_id"/>
                <field name="res_id"/>
                <field name="user_id"/>
                <group expand="0" string="Group By...">
                    <filter name="group_by_user_id" string="User" domain="[]" context="{'group_by':'user_id'}"/>
                    <filter name="group_by_model_id" string="Model" domain="[]" context="{'group_by':'model_id'}"/>
                    <filter name="group_by_res_id" string="Resource ID" domain="[]" context="{'group_by':'res_id'}"/>
                    <filter name="group_by_create_date" string="Date" domain="[]" context="{'group_by':'create_date'}"/>
                    <filter name="group_by_http_session" string="User session" domain="[]" context="{'group_by':'http_session_id'}"/>
                    <filter name="group_by_http_request" string="HTTP Request" domain="[]" context="{'group_by':'http_request_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_g2p_ati_change_tracking_view" model="ir.actions.act_window">
        <field name="name">Change Logs</field>
        <field name="res_model">g2p.change.log.view</field>
        <field name="search_view_id" ref="view_g2p_ati_change_tracking_view_search"/>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_g2p_ati_change_tracking_root"
              name="Change Tracking"
              parent="base.menu_administration"
              sequence="10"
              groups="g2p_ati_change_tracking.group_g2p_ati_change_tracking_user"/>

    <menuitem id="menu_g2p_ati_change_tracking_view"
              name="Changes"
              parent="g2p_ati_change_tracking.menu_g2p_ati_change_tracking_root"
              action="action_g2p_ati_change_tracking_view"
              sequence="100"
              groups="g2p_ati_change_tracking.group_g2p_ati_change_tracking_user"/>

</odoo>
