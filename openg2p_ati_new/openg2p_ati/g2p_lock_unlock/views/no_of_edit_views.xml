<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="no_of_edits_view_tree" model="ir.ui.view">
        <field name="name">no.of.edits.view.tree</field>
        <field name="model">no.of.edits</field>

        <field name="arch" type="xml">
            <tree editable="top">
            <field name="edit_amount" string="Number of edits allowed" />
            </tree>
        </field>
    </record>

    <record id="no_of_edits_action" model="ir.actions.act_window">
        <field name="name">Number of Edits </field>
        <field name="res_model">no.of.edits</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="no_of_edits_menu"
        name="Number of Edits"
        action="no_of_edits_action"
        sequence="100"
        parent="g2p_registry_base.g2p_configuration_menu_root"
    />


</odoo>
