<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_res_partner_form_websub_share_status" model="ir.ui.view">
        <field name="name">res.partner.form.websub.share.status</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="g2p_registry_individual.view_individuals_form" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='other']" position="inside">
                <separator string="Data Sharing" invisible="is_farmer!='yes' or state!='approved'" />
                <group invisible="is_farmer!='yes' or state!='approved'">
                    <group>
                        <field name="websub_last_shared_at" readonly="1" />
                    </group>
                </group>
                <field
                    name="websub_share_status_ids"
                    nolabel="1"
                    readonly="1"
                    invisible="is_farmer!='yes' or state!='approved'"
                >
                    <tree create="0" edit="0" delete="0">
                        <field name="config_id" />
                        <field name="publisher_type" />
                        <field name="last_event_type" />
                        <field name="last_shared_at" />
                        <field name="successful_share_count" />
                    </tree>
                </field>
            </xpath>
        </field>
    </record>
</odoo>
