<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_g2p_land_info_tree" model="ir.ui.view">
        <field name="name">view.g2p.land.information.tree</field>
        <field name="model">g2p.land.information</field>
        <field name="type">tree</field>
        <field name="mode">primary</field>
        <field name="priority" eval="16" />
        <field name="active" eval="True" />
        <field name="arch" type="xml">
            <tree create="0" delete="0" editable="bottom">
                <field name="farmer_id"/>
                <field name="partner_id"  context="{'form_view_ref': 'g2p_ati.g2p_registry_individual_form_view_inherit'}" options="{'no_open': False}"/>
                <field name="land_id"/>
                <field name="total_land_area" widget="g2p_trim_float" />
                <field name="ownership_type" />
              
                <field name="land_kebele"/>
                <field name="land_certificate" />
                <field name="document_slug" column_invisible="1" />
                <field name="document_mimetype" column_invisible="1" />
                <field name="document_name" column_invisible="1" />
                <field name="document_id" column_invisible="1" />
                <field name="document_url" column_invisible="1" />
                <widget name="g2p_ati_document_preview" />
                
                  <field name="remark" />

            </tree>
        </field>
    </record>

    <record id="view_g2p_crop_info_tree" model="ir.ui.view">
        <field name="name">view.g2p.crop.information.tree</field>
        <field name="model">g2p.crop.information</field>
        <field name="type">tree</field>
        <field name="mode">primary</field>
        <field name="priority" eval="16" />
        <field name="active" eval="True" />
        <field name="arch" type="xml">
            <tree create="false" delete="false" edit="false">
                <field name="farmer_id" />
                <field name="partner_id" />
                <field name="crop" />
                <field name="collected_gc" />
                <field name="collected_ec" />
                <field name="season" />
            </tree>
        </field>
    </record>

    <record id="view_g2p_livestock_info_tree" model="ir.ui.view">
        <field name="name">view.g2p.livestock.information.tree</field>
        <field name="model">g2p.livestock.information</field>
        <field name="type">tree</field>
        <field name="mode">primary</field>
        <field name="priority" eval="16" />
        <field name="active" eval="True" />
        <field name="arch" type="xml">
            <tree create="false" delete="false" edit="false">
                <field name="farmer_id" />
                <field name="partner_id" />
                <field name="livestock_type" />
                <field name="number_of_livestock" />
                <!-- <field name="collected_gc"/> -->
                <!-- <field name="collected_ec"/> -->
                <!-- <field name="season"/>  -->
            </tree>
        </field>
    </record>

    <record id="action_g2p_livestock_information_act_window" model="ir.actions.act_window">
        <field name="type">ir.actions.act_window</field>
        <field name="name">Livestock Information</field>
        <field name="res_model">g2p.livestock.information</field>
        <field name="view_mode">tree</field>
    </record>

    <record id="menu_g2p_livestock_info" model="ir.ui.menu">
        <field name="name">Livestock Information</field>
        <field name="sequence" eval="50" />
        <field name="action" ref="action_g2p_livestock_information_act_window" />
        <field name="parent_id" ref="g2p_registry_base.g2p_main_menu_root" />
    </record>

    <record id="action_g2p_crop_information_act_window" model="ir.actions.act_window">
        <field name="type">ir.actions.act_window</field>
        <field name="name">Crop Information</field>
        <field name="res_model">g2p.crop.information</field>
        <field name="view_mode">tree</field>
    </record>

    <record id="menu_g2p_crop_info" model="ir.ui.menu">
        <field name="name">Crop Information</field>
        <field name="sequence" eval="40" />
        <field name="action" ref="action_g2p_crop_information_act_window" />
        <field name="parent_id" ref="g2p_registry_base.g2p_main_menu_root" />
    </record>

    <record id="action_g2p_land_information_act_window" model="ir.actions.act_window">
        <field name="type">ir.actions.act_window</field>
        <field name="name">Land Information</field>
        <field name="res_model">g2p.land.information</field>
        <field name="view_mode">tree</field>
    </record>

    <record id="menu_g2p_land_info" model="ir.ui.menu">
        <field name="name">Land Information</field>
        <field name="sequence" eval="30" />
        <field name="action" ref="action_g2p_land_information_act_window" />
        <field name="parent_id" ref="g2p_registry_base.g2p_main_menu_root" />
    </record>
</odoo>
