<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="g2p_lang_view_tree" model="ir.ui.view">
        <field name="name">g2p.lang.view.form</field>
        <field name="model">g2p.lang</field>
        <field name="arch" type="xml">
            <tree create="true" delete="true" edit="true" editable="bottom">
                <field name="name" />
                <field name="code" />
            </tree>
        </field>
    </record>

    <record id="g2p_lang_action" model="ir.actions.act_window">
        <field name="name">Language</field>
        <field name="res_model">g2p.lang</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="g2p_lang_menu"
        action="g2p_lang_action"
        name="Language"
        sequence="620"
        parent="g2p_registry_base.g2p_configuration_menu_root"
    />
</odoo>
