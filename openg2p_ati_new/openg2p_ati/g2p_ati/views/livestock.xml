<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
   <record id="view_livestock_type_tree" model="ir.ui.view">
        <field name="name">view_livestock_type_tree</field>
        <field name="model">g2p.livestock.type</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <tree create="true" delete="true" edit="true" editable="bottom">
                <field name="name" />
                <field name="code" />
            </tree>
        </field>
    </record>
	<record id="g2p_livestock_type_view_tree_action" model="ir.actions.act_window">
		<field name="name">Livestock Types</field>
		<field name="res_model">g2p.livestock.type</field>
		<field name="view_mode">tree</field>
	</record>
	<menuitem
        id="g2p_livestock_type_menu"
        action="g2p_livestock_type_view_tree_action"
        name="Livestock Types"
        sequence="600"
        parent="g2p_registry_base.g2p_configuration_menu_root"
    />
</odoo>
