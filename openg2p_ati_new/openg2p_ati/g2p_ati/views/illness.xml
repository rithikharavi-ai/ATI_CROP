<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="g2p_illness_view_tree" model="ir.ui.view">
        <field name="name">g2p.illness.type.view.form</field>
        <field name="model">g2p.illness.type</field>
        <field name="arch" type="xml">
        <tree create="true" delete="true" edit="true" editable="bottom">
                    <field name="name" />
                    <field name="code" />
                    <field name="illness_type" />
            </tree>
        </field>
    </record>

    <record id="g2p_illness_action" model="ir.actions.act_window">
        <field name="name">Illness Types</field>
        <field name="res_model">g2p.illness.type</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="g2p_ilness_menu"
        action="g2p_illness_action"
        name="Illness Types"
        sequence="620"
        parent="g2p_registry_base.g2p_configuration_menu_root"
    />
</odoo>
