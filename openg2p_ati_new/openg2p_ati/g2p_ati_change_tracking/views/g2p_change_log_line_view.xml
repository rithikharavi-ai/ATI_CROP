<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_g2p_ati_change_tracking_line_view_tree" model="ir.ui.view">
        <field name="name">g2p.change.log.line.view.tree</field>
        <field name="model">g2p.change.log.line.view</field>
        <field name="arch" type="xml">
            <tree create="0">
                <field name="create_date" string="Changed At"  optional="show"/>
                <field name="field_description" optional="show"/>
                <field name="old_value_text" optional="show" string="Previous"/>
                <field name="new_value_text" optional="show" string="Changed To"/>
                <field name="log_id" optional="hide"/>
                <field name="field_name" optional="hide"/>
                <field name="old_value" optional="hide"/>
                <field name="new_value" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_g2p_ati_change_tracking_line_view_search" model="ir.ui.view">
        <field name="name">g2p.change.log.line.view.search</field>
        <field name="model">g2p.change.log.line.view</field>
        <field name="arch" type="xml">
            <search string="Log Lines">
                <field name="field_name"/>
                <field name="field_description"/>
                <field name="old_value_text" string="Previous"/>
                <field name="new_value_text" string="Changed To"/>
                <field name="log_id"/>
                <group expand="0" string="Group By...">
                    <filter name="group_by_log_id" string="Log ID" domain="[]" context="{'group_by':'log_id'}"/>
                    <filter name="group_by_field_name" string="Field" domain="[]" context="{'group_by':'field_name'}"/>
                    <filter name="group_by_create_date" string="Date" domain="[]" context="{'group_by':'create_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_g2p_ati_change_tracking_line_view" model="ir.actions.act_window">
        <field name="name">Change Entries</field>
        <field name="res_model">g2p.change.log.line.view</field>
        <field name="view_mode">tree</field>
        <field name="search_view_id" ref="view_g2p_ati_change_tracking_line_view_search"/>
        <field name="context">{}</field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_g2p_ati_change_tracking_line_view"
              name="Change Entries"
              parent="g2p_ati_change_tracking.menu_g2p_ati_change_tracking_root"
              action="action_g2p_ati_change_tracking_line_view"
              sequence="101"
              groups="g2p_ati_change_tracking.group_g2p_ati_change_tracking_user"/>

</odoo>
