<odoo>

    <record model="ir.module.category" id="g2p_draft_publish.integration_module">
        <field name="name">ATI Integrations</field>
    </record>




    <record id="rule_imported_record_followers" model="ir.rule">
        <field name="name">Imported Records - Access Rule</field>
        <field name="model_id" ref="g2p_ati_integrations.model_g2p_imported_record" />
        <field name="groups" eval="[(4, ref('base.group_user'))]" />



        <field name="domain_force">[
            '|', ('create_uid', '=', user.id),

            '|', '&amp;',
            
            ('assigned_region', 'in', user.partner_id.asigned_region.ids),
            ('assigned_languages', 'in', [x.id for x in user.partner_id.language_skills]),
            
            ('message_follower_ids.partner_id', '=', user.partner_id.id)
        ]</field>

    </record> 







    



    <record id="rule_imported_record_followers_admin" model="ir.rule">
        <field name="name">Imported Records - Admin Access</field>
        <field name="model_id" ref="g2p_ati_integrations.model_g2p_imported_record" />
        <field name="groups" eval="[(4, ref('g2p_draft_publish.group_int_admin'))]" />
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="g2p_draft_record_following_restriction_rule" model="ir.rule">
        <field name="name">Draft Records - Creator Only</field>
        <field name="model_id" ref="g2p_draft_publish.model_draft_record" />
        <field name="groups" eval="[(4, ref('g2p_draft_publish.group_int_validator'))]" />
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
    </record>

    <record id="g2p_draft_record_approver_region_restriction_rule" model="ir.rule">
        <field name="name">Draft Records - Approver Assigned Region</field>
        <field name="model_id" ref="g2p_draft_publish.model_draft_record" />
        <field name="groups" eval="[(4, ref('g2p_draft_publish.group_int_approver'))]" />
        <field name="domain_force">[
            '|', ('create_uid', '=', user.id),
             ('import_record_id.assigned_region', 'in', user.partner_id.asigned_region.ids)
        ]</field>
    </record>



    <record id="g2p_draft_record_following_admin_restriction_rule" model="ir.rule">
        <field name="name">Draft Records - Admin  Views All</field>
        <field name="model_id" ref="g2p_draft_publish.model_draft_record" />
        <field name="groups" eval="[(4, ref('g2p_draft_publish.group_int_admin'))]" />
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <!-- Disable base draft rules so ATI draft access is creator/region/admin based. -->
    <record id="g2p_draft_publish.g2p_draft_record_following_restriction_rule" model="ir.rule">
        <field name="active" eval="False" />
    </record>

    <record id="g2p_draft_publish.g2p_submitted_validator_record_following_restriction_rule_validator" model="ir.rule">
        <field name="active" eval="False" />
    </record>

    <record id="g2p_draft_publish.g2p_submitted_record_approver_following_restriction_rule" model="ir.rule">
        <field name="active" eval="False" />
    </record>

</odoo>
