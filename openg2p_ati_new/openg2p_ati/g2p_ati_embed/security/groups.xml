<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record model="ir.module.category" id="access_module">
        <field name="name">G2P ATI Embed Dashboard</field>
        <field name="description">Embedding Access</field>
        <field name="sequence">4</field>
    </record>


    <record id="group_g2p_ati_embed_user" model="res.groups">
        <field name="name">G2P ATI Embed User</field>
         <field name="category_id" ref="access_module" />
    </record>


    <record id="group_g2p_ati_embed_admin" model="res.groups">
        <field name="name">G2P ATI Embed Admin</field>
         <field name="category_id" ref="access_module" />
        <field name="implied_ids" eval="[(4, ref('group_g2p_ati_embed_user'))]" />
    </record>






</odoo>
